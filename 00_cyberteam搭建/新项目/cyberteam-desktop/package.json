{
  "name": "cyberteam-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev -w @cyberteam/renderer\" \"npm run dev -w @cyberteam/desktop\"",
    "build": "npm run build -w @cyberteam/renderer && npm run build -w @cyberteam/desktop",
    "check": "npm run typecheck -w @cyberteam/renderer && npm run typecheck -w @cyberteam/desktop",
    "test": "npm run check"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "esbuild": "^0.27.4",
    "next": "^15.2.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.1"
  }
}
