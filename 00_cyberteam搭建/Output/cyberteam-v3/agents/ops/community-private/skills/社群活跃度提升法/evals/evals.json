{
  "skill_name": "社群活跃度提升法",
  "version": "1.0",
  "eval_type": "skill_functional",
  "test_cases": [
    {
      "id": 1,
      "difficulty": "simple",
      "category": "活跃度平稳提升",
      "input": {
        "scenario": "你运营一个200人的学习社群，目前活跃用户30人，日均消息50条，活跃度平稳，希望小幅提升"
      },
      "expected_output": {
        "must_include": [
          "现状诊断",
          "内容规划",
          "互动机制优化"
        ],
        "output_structure": "轻量提升方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "feasibility": "是否可执行",
        "targeted": "方案是否精准",
        "completeness": "流程是否完整"
      }
    },
    {
      "id": 2,
      "difficulty": "medium",
      "category": "死群激活",
      "input": {
        "scenario": "你运营一个500人的社群，目前只有5人活跃，日均消息10条，几乎是死群，需要大幅激活"
      },
      "expected_output": {
        "must_include": [
          "死群原因诊断",
          "内容重新规划",
          "活动设计",
          "KOC培养",
          "激活执行计划"
        ],
        "output_structure": "完整激活方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "方案是否完整",
        "feasibility": "是否可执行",
        "effectiveness": "是否能有效激活"
      }
    },
    {
      "id": 3,
      "difficulty": "hard",
      "category": "品牌私域激活",
      "input": {
        "scenario": "你运营一个500人的品牌私域社群，主要是老客户，但大家都不说话，只有发广告时有人回应，需要激活沉默用户"
      },
      "expected_output": {
        "must_include": [
          "沉默用户分析",
          "价值重塑方案",
          "激活活动设计",
          "互动机制建立",
          "预防再次沉默措施",
          "效果评估体系"
        ],
        "output_structure": "品牌私域完整激活方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "professionalism": "方案是否专业",
        "completeness": "是否覆盖全面",
        "feasibility": "是否可执行",
        "preventive": "预防措施是否完善"
      }
    }
  ],
  "evaluation_methodology": {
    "scoring": "每个维度1-5分，5分制评分",
    "pass_criteria": "总分≥15分（满分25分），且每个维度≥3分",
    "process": "1.现状诊断 2.内容规划 3.活动设计 4.互动机制 5.执行优化"
  },
  "coverage": {
    "场景覆盖": ["小幅提升", "死群激活", "品牌私域激活"],
    "难度分布": {
      "simple": 1,
      "medium": 1,
      "hard": 1
    }
  }
}
