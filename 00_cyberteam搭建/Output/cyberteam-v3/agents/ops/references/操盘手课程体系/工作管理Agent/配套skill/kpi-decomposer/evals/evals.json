{
  "skill_name": "kpi-decomposer",
  "测试案例": [
    {
      "id": "eval-1",
      "难度": "medium",
      "案例": "某SaaS公司季度GMV目标300万，需要拆解到3个销售团队和5个运营岗位",
      "输入": {
        "overall_kpi": "季度GMV 300万",
        "current_baseline": {"上季度GMV": "200万", "销售人数": 6, "客单价": "8000元"},
        "team_structure": {"销售团队": ["华东队3人", "华南队3人", "华北队2人"], "运营团队": ["用户运营", "内容运营", "活动运营", "渠道运营", "数据运营"]},
        "historical_data": {"销售淡季": "Q1", "销售旺季": "Q4", "平均转化率": "15%"}
      },
      "预期输出": {
        "kpi_breakdown": {
          "overall_target": "季度GMV 300万",
          "decomposition_method": "按团队+按时间+按产品线三维拆解",
          "team_targets": [
            {"team": "华东队", "target": "100万", "metrics": ["新签客户数", "续费客户数", "扩收"]},
            {"team": "华南队", "target": "100万", "metrics": ["新签客户数", "续费客户数", "扩收"]},
            {"team": "华北队", "target": "100万", "metrics": ["新签客户数", "续费客户数", "扩收"]}
          ],
          "milestones": [
            {"phase": "第1月", "target": "GMV 80万", "deadline": "月末"},
            {"phase": "第2月", "target": "GMV 100万", "deadline": "月末"},
            {"phase": "第3月", "target": "GMV 120万", "deadline": "季末"}
          ],
          "task_mapping": [
            {"task": "华东新签30客户", "responsible": "华东队", "target_metric": "30万", "deadline": "季末"},
            {"task": "华南新签30客户", "responsible": "华南队", "target_metric": "30万", "deadline": "季末"},
            {"task": "华北新签30客户", "responsible": "华北队", "target_metric": "30万", "deadline": "季末"},
            {"task": "用户运营-提升续费率至40%", "responsible": "用户运营", "target_metric": "续费率40%", "deadline": "季末"},
            {"task": "活动运营-策划2场大促", "responsible": "活动运营", "target_metric": "带动50万GMV", "deadline": "第2月末"}
          ]
        }
      }
    },
    {
      "id": "eval-2",
      "难度": "simple",
      "案例": "电商店铺月度目标是销量1000单，需要分配给客服和运营团队",
      "输入": {
        "overall_kpi": "月度销量1000单",
        "current_baseline": {"当前月销量": "700单", "客服3人", "运营2人"},
        "team_structure": {"客服组": "3人", "运营组": "2人"}
      },
      "预期输出": {
        "kpi_breakdown": {
          "overall_target": "月销量1000单",
          "decomposition_method": "按团队拆解",
          "team_targets": [
            {"team": "客服组", "target": "600单（转化）", "metrics": ["响应率", "转化率", "客单价"]},
            {"team": "运营组", "target": "400单（引流）", "metrics": ["曝光量", "访客数", "加购率"]}
          ],
          "milestones": [
            {"phase": "上半月", "target": "500单", "deadline": "15日"},
            {"phase": "下半月", "target": "500单", "deadline": "月末"}
          ],
          "task_mapping": [
            {"task": "客服转化提升", "responsible": "客服组", "target_metric": "转化率15%", "deadline": "月末"},
            {"task": "推广投放", "responsible": "运营组", "target_metric": "日均UV 500", "deadline": "持续"}
          ]
        }
      }
    }
  ],
  "评分标准": {
    "目标一致性": "分解后各团队目标之和是否等于总体目标",
    "可执行性": "每个任务是否有明确的指标和数值",
    "责任清晰": "是否责任到团队/个人",
    "时间合理": "是否有清晰的里程碑和时间节点",
    "数据支撑": "目标分解是否有历史数据依据"
  }
}
