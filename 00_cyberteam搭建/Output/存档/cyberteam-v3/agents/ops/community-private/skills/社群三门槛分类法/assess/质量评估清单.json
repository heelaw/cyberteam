            "拒绝做法明确，具有辨识度",
            "方法论有创新点"
          ]
        },
        "good": {
          "score": 4,
          "criteria": [
            "有独特个性但创新点不多"
          ]
        },
        "acceptable": {
          "score": 3,
          "criteria": [
            "个性不明显，偏向通用方法论"
          ]
        },
        "poor": {
          "score": 1,
          "criteria": [
            "无独特个性，完全照搬通用模板"
          ]
        }
      }
    },
    {
      "dimension": "规范性",
      "weight": "10%",
      "description": "评估Skill格式和结构的规范程度",
      "score_levels": {
        "excellent": {
          "score": 5,
          "criteria": [
            "完全符合模板规范，字段完整",
