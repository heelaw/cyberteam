  "scoring_method": {
    "total_score": "各维度得分 × 权重之和",
    "max_score": 25,
    "calculation": "20%×完整性 + 20%×实用性 + 20%×专业性 + 20%×严谨性 + 10%×独特个性 + 10%×规范性"
  },
  "pass_threshold": {
    "total_score": "≥85分",
    "min_each_dimension": "每个维度至少3分",
    "note": "满分25分，85分对应21分"
  }
