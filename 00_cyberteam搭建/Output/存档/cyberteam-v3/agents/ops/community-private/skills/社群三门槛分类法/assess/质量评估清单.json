{
  "skill_name": "社群三门槛分类法",
  "version": "1.0",
  "assessment_date": "2026-03-20",
  "evaluation_type": "skill_quality",
  "quality_dimensions": [
    {
      "dimension": "完整性",
      "weight": "20%",
      "description": "评估Skill是否包含三层门槛设计的全部要素",
      "score_levels": {
        "excellent": {
          "score": 5,
          "criteria": [
            "高门槛：身份认同设计完整，有明确条件和验证方式",
            "中门槛：付费/时间投入设计完整，有具体金额或时间标准",
            "低门槛：用户画像筛选条件完整，可量化",
            "执行方案包含完整流程和验证机制"
          ]
        },
        "good": {
          "score": 4,
          "criteria": [
            "三层门槛齐全但部分描述简略",
            "验证机制存在但不够具体"
          ]
        },
        "acceptable": {
          "score": 3,
          "criteria": [
            "仅覆盖2层门槛设计",
            "缺少验证机制"
          ]
        },
        "poor": {
          "score": 1,
          "criteria": [
            "层级不完整或严重缺失关键要素"
          ]
        }
      }
    },
    {
      "dimension": "实用性",
      "weight": "20%",
      "description": "评估Skill产出的方案是否可直接落地执行",
      "score_levels": {
        "excellent": {
          "score": 5,
          "criteria": [
            "可直接落地执行，有明确操作步骤",
