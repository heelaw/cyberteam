            "Workflow Steps 6步完整，每步有输入/处理/输出/成功标准",
            "触发场景描述具体明确"
          ]
        },
        "good": {
          "score": 4,
          "criteria": [
            "Critical Rules完整但略有不足"
          ]
        },
        "acceptable": {
          "score": 3,
          "criteria": [
            "Critical Rules不足5条",
            "Workflow Steps不完整"
          ]
        },
        "poor": {
          "score": 1,
          "criteria": [
            "Critical Rules缺失或不足3条",
            "无标准流程或流程严重缺失"
          ]
        }
      }
    },
    {
      "dimension": "独特个性",
      "weight": "10%",
      "description": "评估Skill是否具有独特的方法论个性",
      "score_levels": {
        "excellent": {
          "score": 5,
          "criteria": [
            "有明确的价值观立场（如\"宁缺毋滥\"）",
