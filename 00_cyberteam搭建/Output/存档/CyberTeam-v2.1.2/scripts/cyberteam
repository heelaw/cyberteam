#!/bin/bash
# ============================================================
# CyberTeam CLI Wrapper
# 一句话交代，整个团队干活。
#
# 底层调用 ClawTeam CLI，统一品牌体验
# 安装: cp cyberteam ~/.local/bin/cyberteam && chmod +x ~/.local/bin/cyberteam
# ============================================================

set -e

CYBERTEAM_VERSION="v2.1"
CLAWTEAM_CMD="clawteam"

# 颜色定义
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

# 横幅
show_banner() {
    cat << 'EOF'
╔═══════════════════════════════════════════════════════════╗
║                                                           ║
║   ██████╗  ██████╗ ███╗   ██╗███╗   ██╗███████╗██████╗ ║
║  ██╔════╝ ██╔═══██╗████╗  ██║████╗  ██║██╔════╝██╔══██╗║
║  ██║  ███╗██║   ██║██╔██╗ ██║██╔██╗ ██║█████╗  ██████╔╝║
║  ██║   ██║██║   ██║██║╚██╗██║██║╚██╗██║██╔══╝  ██╔══██╗║
║  ╚██████╔╝╚██████╔╝██║ ╚████║██║ ╚████║███████╗██║  ██║║
║   ╚═════╝  ╚═════╝ ╚═╝  ╚═══╝╚═╝  ╚═══╝╚══════╝╚═╝  ╚═╝║
║                                                           ║
║   一句话交代，整个团队干活。                             ║
║   Let AI teams collaborate like human teams.              ║
║                                                           ║
╚═══════════════════════════════════════════════════════════╝
EOF
}

# 帮助信息
show_help() {
    show_banner
    cat << EOF

${CYAN}用法:${RESET}
  cyberteam <命令> [选项] [参数]

${CYAN}团队管理${RESET}:
  cyberteam team spawn-team <name>     创建新团队
  cyberteam team discover                列出所有团队
  cyberteam team status <name>         查看团队状态
  cyberteam team snapshot <name> --tag  创建快照
  cyberteam team restore <name> --tag   恢复快照
  cyberteam team cleanup <name> --force 删除团队

${CYAN}Agent 管理${RESET}:
  cyberteam spawn [backend] <cmd>         Spawn Agent
  cyberteam inbox send <team> <agent>    发送消息
  cyberteam inbox watch <team>           监听消息

${CYAN}任务管理${RESET}:
  cyberteam task create <team> <title>   创建任务
  cyberteam task list <team>             列出任务
  cyberteam task update <team> <id>      更新任务
  cyberteam task wait <team>             等待任务完成

${CYAN}监控看板${RESET}:
  cyberteam board show <team>             显示看板
  cyberteam board live <team>             实时监控
  cyberteam board attach <team>           附加到看板

${CYAN}配置管理${RESET}:
  cyberteam profile list                  列出配置
  cyberteam profile show <name>           显示配置
  cyberteam profile wizard                交互式配置向导
  cyberteam profile doctor [name]         诊断配置

${CYAN}系统命令${RESET}:
  cyberteam --version                     显示版本
  cyberteam --help                        显示帮助

${YELLOW}示例${RESET}:
  cyberteam team spawn-team my-team -d "我的团队"
  cyberteam spawn --team my-team --agent-name worker1 --task "写代码"
  cyberteam board live my-team --interval 5

${GREEN}了解更多${RESET}:
  https://github.com/cyberwiz/CyberTeam

EOF
}

# 版本信息
show_version() {
    show_banner
    echo ""
    echo -e "  ${CYAN}版本${RESET}: ${BOLD}$CYBERTEAM_VERSION${RESET}"
    echo -e "  ${CYAN}底层框架${RESET}: ClawTeam CLI"
    echo -e "  ${CYAN}品牌${RESET}: CyberTeam"
    echo ""
    echo "  一句话交代，整个团队干活。"
    echo ""
}

# 检查 clawteam 是否安装
check_clawteam() {
    if ! command -v $CLAWTEAM_CMD &> /dev/null; then
        echo -e "${RED}错误: CyberTeam 需要 ClawTeam CLI 作为底层框架${RESET}"
        echo -e ""
        echo "安装 ClawTeam:"
        echo "  pip install clawteam"
        echo ""
        echo "或访问: https://github.com/clawteam/clawteam"
        exit 1
    fi
}

# 预处理命令（替换 cyberteam 为 clawteam）
preprocess_args() {
    local cmd="$1"
    shift
    local args=("$@")

    # 替换子命令
    case "$cmd" in
        team|spawn|inbox|task|board|profile|context|plan|lifecycle)
            # 这些子命令在 clawteam 和 cyberteam 中相同
            ;;
    esac

    # 打印执行的命令（调试模式）
    if [[ "${CYBERTEAM_DEBUG:-0}" == "1" ]]; then
        echo -e "${YELLOW}[DEBUG] 执行: $CLAWTEAM_CMD $cmd ${args[*]}${RESET}"
    fi
}

# 主函数
main() {
    # 无参数时显示帮助
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi

    # 处理全局选项
    case "$1" in
        --help|-h)
            show_help
            exit 0
            ;;
        --version|-v)
            show_version
            exit 0
            ;;
        --debug)
            export CYBERTEAM_DEBUG=1
            shift
            ;;
    esac

    # 检查依赖
    check_clawteam

    # 预处理并执行
    local cmd="$1"
    shift

    # 特殊命令处理
    case "$cmd" in
        # team 子命令
        team)
            local subcmd="${1:-}"
            shift  # 跳过 subcmd，剩余参数传给 clawteam
            case "$subcmd" in
                spawn-team)
                    show_banner
                    echo -e "${CYAN}> 创建 CyberTeam 团队...${RESET}"
                    $CLAWTEAM_CMD team spawn-team "$@"
                    ;;
                status)
                    $CLAWTEAM_CMD team status "$@"
                    ;;
                list|discover)
                    $CLAWTEAM_CMD team discover "$@"
                    ;;
                snapshot)
                    $CLAWTEAM_CMD team snapshot "$@"
                    ;;
                restore)
                    $CLAWTEAM_CMD team restore "$@"
                    ;;
                cleanup)
                    $CLAWTEAM_CMD team cleanup "$@"
                    ;;
                *)
                    $CLAWTEAM_CMD team "$@"
                    ;;
            esac
            ;;

        # spawn 命令
        spawn)
            show_banner
            echo -e "${CYAN}> Spawn CyberTeam Agent...${RESET}"
            $CLAWTEAM_CMD spawn "$@"
            ;;

        # inbox 命令
        inbox)
            $CLAWTEAM_CMD inbox "$@"
            ;;

        # task 命令
        task)
            $CLAWTEAM_CMD task "$@"
            ;;

        # board 命令
        board)
            local subcmd="${1:-}"
            case "$subcmd" in
                show|attach|serve|gource)
                    $CLAWTEAM_CMD board "$@"
                    ;;
                live)
                    echo -e "${CYAN}> 启动 CyberTeam 实时监控...${RESET}"
                    $CLAWTEAM_CMD board live "$@"
                    ;;
                overview)
                    $CLAWTEAM_CMD board overview "$@"
                    ;;
                *)
                    $CLAWTEAM_CMD board "$@"
                    ;;
            esac
            ;;

        # profile 命令
        profile)
            $CLAWTEAM_CMD profile "$@"
            ;;

        # context 命令
        context)
            $CLAWTEAM_CMD context "$@"
            ;;

        # plan 命令
        plan)
            $CLAWTEAM_CMD plan "$@"
            ;;

        # lifecycle 命令
        lifecycle)
            $CLAWTEAM_CMD lifecycle "$@"
            ;;

        # launch 命令 (CyberTeam 特色)
        launch)
            show_banner
            echo -e "${GREEN}> 启动 CyberTeam 自主运营团队...${RESET}"
            echo ""

            local team_name="${1:-cyberteam-ops}"
            local goal="${2:-}"

            if [[ -z "$goal" ]]; then
                echo -e "${YELLOW}使用默认目标: 一句话交代，整个团队干活${RESET}"
                goal="一句话交代，整个团队干活"
            fi

            echo -e "${CYAN}团队名称${RESET}: $team_name"
            echo -e "${CYAN}团队目标${RESET}: $goal"
            echo ""

            # 创建团队
            $CLAWTEAM_CMD team spawn-team "$team_name" -d "CyberTeam v2.1 自主运营"

            echo ""
            echo -e "${GREEN}✅ CyberTeam 团队已启动！${RESET}"
            echo ""
            echo "下一步:"
            echo "  cyberteam board show '$team_name'   # 查看看板"
            echo "  cyberteam board live '$team_name'  # 实时监控"
            ;;

        # 未知命令
        *)
            echo -e "${RED}未知命令: $cmd${RESET}"
            echo ""
            show_help
            exit 1
            ;;
    esac
}

# 运行
main "$@"
