# =============================================================================
# CyberTeam Desktop - .gitignore
# Electron + React + Node.js 项目规范
# =============================================================================

# ========================
# Dependencies
# ========================
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ========================
# Build outputs
# ========================
dist/
dist-electron/
out/
build/                     # electron-builder output
*.exe                      # Windows build
*.dmg                      # macOS installer
*.pkg                      # macOS installer
*.app                      # macOS app bundle (if built locally)
*.ipa                      # iOS app
*.deb                      # Linux deb
*.rpm                      # Linux rpm
*.AppImage                 # Linux AppImage
*.snap                     # Linux snap

# ========================
# Electron specific
# ========================
.electron/
electron-builder.yml

# ========================
# Vite / React
# ========================
dist-sourcemap/
*.local

# ========================
# Tauri (旧版，迁移后删除)
# ========================
src-tauri/target/
src-tauri/Cargo.lock
src-tauri/gen/
dist-tauri/

# ========================
# IDE
# ========================
.idea/
.vscode/
*.swp
*.swo
*.swn
*.sublime-workspace
*.sublime-project
.project
.settings/

# ========================
# OS
# ========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable
desktop.ini
$RECYCLE.BIN/

# ========================
# Logs
# ========================
*.log
logs/
npm-log/
yarn-log/
pnpm-log/
*.sqlite
*.sqlite-wal
*.sqlite-shm

# ========================
# Environment / Secrets
# ========================
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
*.crt
*.mobileprovision

# ========================
# Test / Coverage
# ========================
coverage/
.nyc_output/
*.lcov
playwright-report/
test-results/
e2e-results/

# ========================
# Temp files
# ========================
*.tmp
*.temp
*.bak
*.backup
*.swp
*.~*
*.orig
*.crswap

# ========================
# Claude / AI related
# ========================
.mcp/
.claude/
.mcp.json
.releaserc.json
.commitlintrc.json

# ========================
# CyberTeam specific
# ========================
# 数据库文件（每个机器不同）
*.db

# 用户数据（每个机器不同）
# ~/Library/Application Support/CyberTeam/
# 这个目录不要提交到 Git

# 项目特定（不应该进 Git 的）
# projects/
# *.workspace
