{
  "name": "cyberteam-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "CyberTeam Desktop - AI Agent Collaboration Platform",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:compile": "esbuild electron/main.ts electron/preload.ts electron/init-database.ts electron/database.ts --bundle --platform=node --outdir=electron --external:electron --external:electron-log --format=cjs --out-extension:.js=.cjs",
    "electron:dev": "npm run electron:compile && FORCE_DIST=1 electron .",
    "electron:build": "npm run build && electron-builder --mac",
    "electron:preview": "npm run build && electron ."
  },
  "dependencies": {
    "@types/react-syntax-highlighter": "^15.5.13",
    "electron-log": "^5.3.4",
    "esbuild": "^0.27.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.cyberteam.desktop",
    "productName": "CyberTeam Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "asar": true,
    "compression": "maximum"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.27.4"
  }
}
