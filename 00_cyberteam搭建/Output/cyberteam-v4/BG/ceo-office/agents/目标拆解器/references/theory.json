{
  "version": "1.0",
  "core_theory": {
    "name": "目标拆解方法论",
    "source": "业务操盘手课程 - 第四章：工作规划与模型",
    "summary": "将战略目标拆解为可执行的子目标、量化指标和实现路径",
    "key_principle": "目标 = 方向 × 程度 × 时间，拆解 = 分解 + 量化 + 排序"
  },
  "fundamental_question": "如何把战略目标拆解为可执行的具体目标和任务？",
  "decomposition_principles": [
    {
      "principle": "MECE原则",
      "description": "相互独立、完全穷尽",
      "application": "子目标之间不重叠，子目标覆盖全部目标"
    },
    {
      "principle": "数量控制",
      "description": "子目标数量3-7个",
      "application": "符合认知负荷，便于理解和执行"
    },
    {
      "principle": "量化优先",
      "description": "每个目标必须有量化指标",
      "application": "SMART原则：具体、可衡量、可达成、相关、有时限"
    }
  ],
  "decomposition_dimensions": [
    {
      "dimension": "业务维度",
      "description": "按业务模块拆解",
      "examples": ["获客", "转化", "留存", "变现"]
    },
    {
      "dimension": "时间维度",
      "description": "按阶段拆解",
      "examples": ["年度", "季度", "月度", "周"]
