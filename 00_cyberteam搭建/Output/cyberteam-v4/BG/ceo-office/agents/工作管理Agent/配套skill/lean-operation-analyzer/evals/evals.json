{
  "skill_name": "lean-operation-analyzer",
  "测试案例": [
    {
      "id": "eval-1",
      "难度": "medium",
      "案例": "某在线教育公司课程完课率仅25%，需要分析并优化流程提升至40%",
      "输入": {
        "process_description": "用户报名→等待开课→自主学习→课程结束",
        "current_metrics": {"完课率": "25%", "课程数": 20, "平均课时": "40节"},
        "problem_areas": ["开课第一周流失30%", "中间章节通过率骤降", "无课后答疑"]
      },
      "预期输出": {
        "analysis_result": {
          "waste_identification": [
            {"浪费类型": "等待浪费", "具体表现": "等待开课周期过长", "影响": "用户热情消退"},
            {"浪费类型": "过度加工", "具体表现": "课程内容过深超出学员水平", "影响": "学习挫败感"},
            {"浪费类型": "库存浪费", "具体表现": "课程堆积无人学习", "影响": "资源浪费"},
            {"浪费类型": "搬运浪费", "具体表现": "课程内容重复搬运至多个平台", "影响": "效率低下"}
          ],
          "value_flow_analysis": {
            "增值活动": ["直播授课", "答疑互动", "作业批改"],
            "非增值活动": ["重复录课", "多平台搬运", "无效等待"],
            "瓶颈识别": ["开课等待期", "课程中期难度跃升点"]
          },
          "optimization_recommendations": [
            {"优化点": "改为滚动开班", "预期效果": "减少等待浪费", "实施难度": "低"},
            {"优化点": "增加课前水平测试", "预期效果": "匹配合适难度", "实施难度": "中"},
            {"优化点": "设置章节闯关模式", "预期效果": "降低中途流失", "实施难度": "中"}
          ],
          "expected_outcomes": {"目标完课率": "40%", "提升路径": "滚动开班+闯关模式"}
        }
      }
    }
  ],
  "评分标准": {
    "浪费识别": "是否能识别出至少3种浪费类型",
    "原因分析": "是否深入分析浪费产生的根本原因",
    "优化建议": "建议是否有针对性和可操作性",
    "价值流": "是否清晰区分增值与非增值活动",
    "实施可行性": "优化建议是否考虑资源投入和实施难度"
  }
}
