      "expected_output": "包含Attention/Interest/Desire/Action四个阶段的完整文案",
      "files": [],
      "assertions": [
        {
          "type": "contains",
          "field": "Attention",
          "expected": "标题"
        },
        {
          "type": "contains",
          "field": "Interest",
          "expected": "痛点"
        },
        {
          "type": "contains",
          "field": "Desire",
          "expected": "收益"
        },
        {
          "type": "contains",
          "field": "Action",
          "expected": "CTA"
        }
      ]
    },
    {
      "id": 2,
      "difficulty": "medium",
      "name": "在线课程推广AIDA文案",
      "prompt": "请使用AIDA模型为以下课程撰写推广文案：\n\n## 课程信息\n- 课程类型：数据分析训练营\n- 目标用户：想转行的在职人员\n- 核心卖点：体系化学习、实战项目、就业指导\n- 场景：公众号推广\n\n请按照AIDA结构撰写",
      "expected_output": "完整AIDA四阶段文案，包含情感触发和社会证明",
      "files": [],
      "assertions": [
        {
          "type": "contains",
          "field": "Desire",
          "expected": "量化"
        },
        {
          "type": "contains",
          "field": "Action",
          "expected": "紧迫感"
        }
