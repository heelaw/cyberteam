{
  "skill_name": "转载文章四维度判断法",
  "evals": [
    {
      "id": "eval-001",
      "difficulty": "simple",
      "scenario": "判断一篇行业分析文章是否可转载",
      "input": {
        "article_title": "2024年AI行业趋势报告：这5个方向必须关注",
        "author": "某科技媒体",
        "original_source": "微信公众号-某科技媒体",
        "original_mark": "已标原创",
        "account_type": "企业服务号",
        "account_focus": "帮助中小企业数字化转型"
      },
      "expected_output": {
        "step1_originality": {
          "conclusion": "存疑",
          "reason": "已标原创，需验证授权"
        },
        "step2_relevance": {
          "score": 4,
          "matching_points": ["AI趋势与数字化转型高度相关", "目标用户关心AI落地"],
          "conflict_points": ["文章偏宏观，我的粉丝需要实操"]
        },
        "step3_quality": {
          "score": 4,
          "pros": ["数据详实", "观点清晰", "有参考价值"],
          "cons": ["部分数据来源不明", "缺少具体落地路径"]
        },
        "step4_copyright": {
          "conclusion": "需申请授权",
          "required_elements": ["联系作者申请授权", "保留授权截图", "标注来源和作者"]
        },
        "final_advice": "可转载但需先获得作者授权，建议补充企业落地案例"
      },
      "evaluation_criteria": [
        "四维判断完整，每维有评分和结论",
        "给出明确的是/否/有条件转载建议",
        "列出转载必须执行的操作项"
      ]
    },
    {
      "id": "eval-002",
