{
  "skill_name": "content-topic-selector",
  "测试案例": [
    {
      "id": "eval-1",
      "难度": "medium",
      "案例": "某职场教育账号当前选题随意，爆款率低，需要系统化选题",
      "输入": {
        "账号定位": "帮助职场新人快速成长",
        "粉丝量": "5万",
        "近期数据": {"平均点赞": "500", "最高点赞": "3000", "评论热词": "加班/工资/领导"},
        "目标": "提升爆款率至20%"
      },
      "预期输出": {
        "选题方向": [
          {
            "方向": "痛点共鸣型",
            "选题": ["为什么你加班到半夜领导却不满意", "入职第一年最容易踩的5个坑", "工资4000和40000的人差在哪"],
            "爆款率": "高",
            "适用阶段": "涨粉期"
          },
          {
            "方向": "价值干货型",
            "选题": ["会议发言万能公式", "向上汇报的3个技巧", "如何优雅地拒绝不合理工作"],
            "爆款率": "中",
            "适用阶段": "粘性期"
          },
          {
            "方向": "情绪释放型",
            "选题": ["打工人的年度总结", "周一早上不想上班", "裸辞后的真实感受"],
            "爆款率": "极高",
            "适用阶段": "爆发期"
          }
        ],
        "选题优先级": {"本周": "痛点共鸣型1篇+情绪释放型1篇", "下周": "价值干货型2篇"},
        "避坑选题": ["太泛泛的职场道理", "纯说教内容", "与目标用户无关的话题"]
      }
    }
  ],
  "评分标准": {
    "方向完整性": "是否覆盖不同类型选题方向",
    "数据驱动": "是否基于账号数据选方向",
    "可执行性": "选题是否可落地创作",
    "爆款潜力": "选题是否有爆款潜力"
  }
}
