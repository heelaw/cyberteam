      "权重": 30,
      "评估项": [
        {
          "条目": "禁止自嗨式选题",
          "检查点": "每个选题必须有用户痛点支撑，不能是作者主观认为有价值的内容",
          "合格标准": "痛点描述使用用户语言，有具体场景"
        },
        {
          "条目": "禁止纯追热点",
          "检查点": "热点选题必须有与账号定位相关联的核心痛点",
          "合格标准": "热点选题需附冷启动策略"
        },
        {
          "条目": "禁止抄袭同行",
          "检查点": "选题必须有独特角度或差异化洞察",
          "合格标准": "提供与竞品的差异化说明"
        },
        {
          "条目": "禁止只看阅读量",
          "检查点": "成功标准必须包含用户问题解决率",
          "合格标准": "设定可量化的效果指标"
        },
        {
          "条目": "禁止忽略时效",
          "检查点": "季节性/节日性选题必须提前4周规划",
          "合格标准": "提供时间节点规划表"
        },
        {
          "条目": "禁止忽视资源",
          "检查点": "每个选题必须评估执行难度和团队能力匹配度",
          "合格标准": "提供资源需求清单"
        }
      ]
    },
    "workflow_compliance": {
      "权重": 40,
      "评估项": [
        {
          "步骤": "Step1-痛点挖掘",
          "检查点": "输出6个痛点，每个痛点对应具体场景",
          "合格标准": "6个痛点 × 2个场景 = 完整痛点地图"
        },
        {
          "步骤": "Step2-选题判断",
          "检查点": "四维打分完整，每个入选选题≥16分",
          "合格标准": "总分≥16分，且每个维度≥1分"
        },
        {
          "步骤": "Step3-优先级排序",
          "检查点": "最终输出包含执行顺序、推送日期、素材清单",
          "合格标准": "三要素齐全，有周/月维度规划"
        }
      ]
    },
    "output_format": {
      "权重": 30,
      "评估项": [
        {
          "条目": "痛点清单格式",
          "检查点": "包含痛点描述、对应场景、用户语言表达",
          "合格标准": "表格化呈现，有优先级标注"
        },
        {
          "条目": "选题评分表格式",
          "检查点": "四维打分完整，有总分和排名",
          "合格标准": "可视化表格TOP3高亮"
        },
        {
          "条目": "最终输出格式",
          "检查点": "执行顺序清晰，时间节点明确",
          "合格标准": "可直接用于下周内容排期"
