{
  "skill_name": "转载文章四维度判断法",
  "version": "1.0",
  "quality_standards": {
    "critical_rules_compliance": {
      "权重": 30,
      "评估项": [
        {
          "条目": "禁止转载原创声明文章",
          "检查点": "凡标注'原创'的文章，必须验证授权情况",
          "合格标准": "无原创标或有用明确的转载授权"
        },
        {
          "条目": "禁止转载洗稿内容",
          "检查点": "通过多平台搜索验证文章是否存在洗稿/拼接",
          "合格标准": "核心观点有独特表达，非拼接而成"
        },
        {
          "条目": "禁止无授权转载",
          "检查点": "必须获得作者明确授权，口头承诺不算",
          "合格标准": "提供授权截图或书面证明"
        },
        {
          "条目": "禁止忽略调性匹配",
          "检查点": "评估文章风格与账号粉丝的契合度",
          "合格标准": "相关性评分≥3分"
        },
        {
          "条目": "禁止只图阅读量",
          "检查点": "评估文章对粉丝的实际价值",
          "合格标准": "质量评分≥3分"
        },
        {
          "条目": "禁止忽视版权细节",
          "检查点": "检查图片/字体/数据/案例的版权情况",
          "合格标准": "提供版权风险清单"
        }
      ]
    },
    "workflow_compliance": {
      "权重": 40,
      "评估项": [
        {
          "步骤": "Step1-原创性评估",
          "检查点": "核查原创标签、洗稿痕迹、授权情况",
          "合格标准": "输出明确结论：通过/存疑/不通过"
        },
        {
          "步骤": "Step2-相关性评估",
          "检查点": "分析主题匹配度、粉丝需求、调性契合",
          "合格标准": "评分1-5分，输出相关点和冲突点"
        },
        {
          "步骤": "Step3-质量评估",
          "检查点": "评估干货价值、数据可靠性、可读性、转发价值",
          "合格标准": "评分1-5分，输出优缺点清单"
        },
        {
          "步骤": "Step4-版权评估",
          "检查点": "确认授权范围、图片来源、字体使用",
          "合格标准": "输出合规性结论和必须要素"
        }
      ]
    },
    "output_format": {
      "权重": 30,
      "评估项": [
        {
          "条目": "四维判断结论",
          "检查点": "每个维度有明确评分和判断结论",
          "合格标准": "表格化呈现，结论清晰"
        },
        {
          "条目": "最终建议",
          "检查点": "明确给出可转载/需修改/不可转载的建议",
          "合格标准": "建议明确，有行动指导"
        },
        {
          "条目": "操作清单",
          "检查点": "如可转载，列出必须执行的操作项",
          "合格标准": "包含来源标注、授权获取等具体步骤"
        }
      ]
    }
  },
  "quality_score": {
    "总分": 100,
    "合格线": 75,
    "评分维度": ["Critical Rules合规(30%)", "Workflow执行(40%)", "输出格式(30%)"]
  }
}
