{
  "version": "1.0",
  "test_cases": [
    {
      "id": "1",
      "scenario": "电商公司业务模块优先级分析",
      "description": "一家年营收5000万的电商公司，有获客、转化、供应链、客服四个业务模块，需要分析老板关注点",
      "difficulty": "medium",
      "input": {
        "company_stage": "增长期",
        "business_modules": [
          {"name": "获客", "revenue_contribution": "30%", "growth_potential": "高"},
          {"name": "转化", "revenue_contribution": "直接相关", "growth_potential": "高"},
          {"name": "供应链", "revenue_contribution": "间接支撑", "growth_potential": "中"},
          {"name": "客服", "revenue_contribution": "间接影响", "growth_potential": "低"}
        ],
        "boss_background": "销售导向，关注收入增长"
      },
      "expected_output": {
        "priority_ranking": ["获客", "转化", "供应链", "客服"],
        "attention_focus": ["收入增长", "转化率提升", "供应链稳定性"],
        "resource_suggestion": "获客和转化优先投入"
      },
      "evaluation_points": [
        "关注点识别准确",
        "优先级排序合理",
        "建议实用可落地"
      ]
    },
    {
      "id": "2",
      "scenario": "在线教育公司业务模块优先级分析",
      "description": "一家在线教育公司，有师资、课程、获客、运营四个模块",
      "difficulty": "simple",
      "input": {
        "company_stage": "早期",
        "business_modules": [
          {"name": "师资", "description": "教师招聘培训"},
          {"name": "课程", "description": "课程研发"},
          {"name": "获客", "description": "招生获客"},
          {"name": "运营", "description": "学员服务"}
        ],
        "boss_background": "产品导向，关注课程质量"
      },
      "expected_output": {
        "priority_ranking": "师资和课程应优先",
        "attention_focus": ["课程质量", "师资储备", "获客效率"]
      },
      "evaluation_points": [
        "关注点识别准确",
        "优先级排序合理"
      ]
    }
  ],
  "evaluation_criteria": {
    "focus_accuracy": "准确识别老板关注的核心维度",
    "priority_logic": "优先级判断逻辑清晰合理",
    "suggestion_practical": "建议可执行、可落地",
    "schema_completeness": "输入输出格式规范"
  }
}
