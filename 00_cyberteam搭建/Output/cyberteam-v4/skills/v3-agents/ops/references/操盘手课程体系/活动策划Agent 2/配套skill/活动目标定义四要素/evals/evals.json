      "case_id": "eval_001",
      "case_name": "电商平台拉新活动目标定义",
      "difficulty": "medium",
      "scenario": "某电商平台想在618大促期间开展新用户拉新活动，目标是在活动期间获取10万新注册用户。平台现有日活100万，但新用户转化率较低（仅3%）。预算100万，周期30天。",
      "expected_output": {
        "业务目标": "在618大促期间新增10万新注册用户，扩大用户规模",
        "目标类型": "拉新",
        "量化指标": {
          "核心KPI": "新用户注册数",
          "基准值": "日常日均拉新1000人（活动前30天均值）",
          "目标值": "活动期间30天新增10万人",
          "目标提升幅度": "日均从1000人提升至3333人，提升233%",
          "辅助KPI": "注册转化率、获客成本"
        },
        "目标受众": {
          "受众类型": "潜在新用户（未在平台注册的用户）",
          "人群画像": [
            "25-35岁女性为主",
            "有网购习惯但未在平台注册",
            "价格敏感度高"
          ],
          "预估规模": "潜在目标用户约500-800万",
          "触达方式": "抖音/快手短视频投放、社交裂变"
        },
        "时间窗口": {
          "活动周期": "2024-06-01 至 2024-06-30",
          "预热期": "06-01至06-15（15天蓄水）",
          "爆发期": "06-16至06-18（618高潮3天）",
          "长尾期": "06-19至06-30（12天持续转化）",
          "关键节点": [
            "06-01: 活动正式上线",
            "06-15: 预热期截止，投放加码",
            "06-16-18: 618爆发期全力冲刺",
            "06-30: 活动结束，数据复盘"
          ]
        },
        "风险提示": [
          "转化率可能低于预期（3%→5%假设过于乐观）",
          "竞品同期大促分流",
          "预算可能不足以支撑10万目标"
        ]
      },
      "evaluation_criteria": {
        "目标清晰度": [
          "业务目标是否具体明确",
          "目标类型是否正确（拉新）"
        ],
        "KPI量化度": [
          "KPI是否可量化",
          "基准值和目标值是否设定",
          "KPI是否可追踪"
        ],
        "受众精准度": [
          "目标受众是否精准",
          "受众画像是否具体"
        ],
        "时间合理性": [
          "活动周期是否合理",
          "关键节点是否清晰"
        ]
      }
    },
    {
      "case_id": "eval_002",
      "case_name": "在线教育产品促活活动目标定义",
