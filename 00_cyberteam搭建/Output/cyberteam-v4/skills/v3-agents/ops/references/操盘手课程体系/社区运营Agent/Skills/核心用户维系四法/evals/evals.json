{
  "skill_name": "核心用户维系四法",
  "version": "1.0",
  "eval_type": "skill_functional",
  "test_cases": [
    {
      "id": 1,
      "difficulty": "simple",
      "category": "基础维系",
      "input": {
        "scenario": "产品经理社区有20位核心用户，月预算1000元，运营人力1人，需要做日常维系"
      },
      "expected_output": {
        "must_include": ["核心用户分级标准", "四维权益体系（荣誉/优先/情感/物质）", "月度维护计划"],
        "output_structure": "分级+权益+计划",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "是否包含核心要素",
        "feasibility": "预算内是否可执行"
      }
    },
    {
      "id": 2,
      "difficulty": "medium",
      "category": "流失挽回",
      "input": {
        "scenario": "技术社区有50位核心用户，近期活跃度下降30%，需要设计挽回方案"
      },
      "expected_output": {
        "must_include": ["流失原因分析", "用户画像档案", "针对性挽回策略", "权益升级方案", "预警机制优化"],
        "output_structure": "分析+画像+策略+机制",
        "min_score": 3
      },
      "evaluation_criteria": {
        "analysis": "流失原因分析是否准确",
        "strategy": "挽回策略是否有效"
      }
    },
    {
      "id": 3,
      "difficulty": "hard",
      "category": "体系化建设",
      "input": {
        "scenario": "计划建立完整的核心用户运营体系，支撑10000+用户的社区，年度预算50万"
      },
      "expected_output": {
        "must_include": ["用户分层模型", "完整权益体系设计", "维护SOP", "团队分工和KPI", "效果监测体系", "风险预案"],
        "output_structure": "完整运营体系方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "systematic": "体系是否完整可持续",
        "scalable": "是否能支撑规模扩展"
      }
    }
  ],
  "evaluation_methodology": {
    "scoring": "每个维度1-5分，5分制评分",
    "pass_criteria": "总分≥15分（满分25分），且每个维度≥3分",
    "process": "1.用户识别 2.画像建立 3.权益设计 4.维护计划 5.执行反馈 6.优化迭代"
  }
}
