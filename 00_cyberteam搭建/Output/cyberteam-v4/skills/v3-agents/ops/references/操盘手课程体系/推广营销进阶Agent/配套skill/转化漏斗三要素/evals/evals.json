    {
      "id": "eval-001",
      "name": "在线教育课程转化漏斗诊断",
      "difficulty": "simple",
      "input": {
        "场景": "一款1999元的职场技能在线课程投放30天数据",
        "曝光量": 100000,
        "点击量": 1500,
        "转化量": 45,
        "行业": "在线教育",
        "客单价": "1999元"
      },
      "expected_output": {
        "数据完整性": true,
        "ctr计算": "1.5%",
        "cvr计算": "3%",
        "行业对标": "CTR略低于行业均值1.5%（参考0.3-1.5%），CVR在正常范围",
        "卡点诊断": "CTR偏低是主要卡点，说明素材吸引力不够或定向不精准",
        "优化建议": ["优化投放素材开头", "精细化定向人群", "测试不同渠道"]
      },
      "evaluation_criteria": [
        "数据计算是否正确",
        "行业对标是否准确匹配在线教育行业",
        "卡点定位是否精准（CTR还是CVR）",
        "优化建议是否具体可执行"
      ],
      "validation_points": [
        "CTR计算正确（1500/100000=1.5%）",
        "CVR计算正确（45/1500=3%）",
        "行业对标准确",
        "卡点定位精准"
      ]
    },
