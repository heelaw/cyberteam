{
  "skill_name": "user-growth-promoter",
  "测试案例": [
    {
      "id": "eval-1",
      "难度": "medium",
      "案例": "某拼团电商APP当前用户50万，目标年度增长至150万，需制定增长策略",
      "输入": {
        "growth_target": "年度用户增长100万",
        "current_user_base": 500000,
        "budget": "年度增长预算500万",
        "channel_data": {"当前获客成本": "友商平均15元/人", "现有渠道": ["微信裂变", "短视频投放", "应用商店"]}
      },
      "预期输出": {
        "growth_analysis": {
          "current_status": "成长期产品，用户基盘50万，有拼团基础但裂变效率低",
          "growth_rate": "当前月增速5%，需提升至月增速10%+",
          "bottlenecks": ["获客成本高于行业水平", "裂变系数仅1.2（需提升至1.5）", "新用户激活率仅40%"]
        },
        "growth_strategy": {
          "primary_lever": "裂变效率提升（裂变系数1.2→1.5）",
          "secondary_levers": ["新用户激活优化", "渠道投放ROI提升", "老带新机制升级"],
          "implementation_sequence": ["1.优化裂变机制 → 2.提升激活率 → 3.扩量渠道投放"]
        },
        "specific_plans": [
          {
            "initiative": "裂变机制升级",
            "expected_output": "裂变系数1.2→1.5，带来额外30万用户",
            "resource_requirement": "技术开发2人，激励成本100万",
            "timeline": "Q1完成"
          },
          {
            "initiative": "新用户激活优化",
            "expected_output": "激活率40%→60%，减少流失",
            "resource_requirement": "产品优化1人，A/B测试成本20万",
            "timeline": "Q1-Q2"
          },
          {
            "initiative": "短视频渠道扩量",
            "expected_output": "ROI从1.5提升至2.0，额外获客50万",
            "resource_requirement": "投放预算300万",
            "timeline": "Q2-Q4"
          }
        ]
      }
    },
    {
      "id": "eval-2",
      "难度": "simple",
      "案例": "线下健身房需要增长策略，目标新会员增长50%",
      "输入": {
        "growth_target": "新会员增长50%",
        "current_user_base": 1000,
        "budget": "季度推广预算10万"
      },
      "预期输出": {
        "growth_analysis": {
          "current_status": "社区健身房，有稳定老会员基础",
          "growth_rate": "季度新会员增长10%，低于目标",
          "bottlenecks": ["曝光不足", "缺乏传播机制", "转化环节流失"]
        },
        "growth_strategy": {
          "primary_lever": "老带新机制",
          "secondary_levers": ["线上曝光", "地推转化"],
          "implementation_sequence": ["1.老带新激励 → 2.抖音/小红书种草 → 3.地推体验"]
        },
        "specific_plans": [
          {
            "initiative": "老带新激励",
            "expected_output": "老会员推荐转化50人",
            "resource_requirement": "推荐奖励成本3万",
            "timeline": "Q1"
          },
          {
            "initiative": "抖音种草",
            "expected_output": "到店体验100人",
            "resource_requirement": "内容制作+投放5万",
            "timeline": "Q1-Q2"
          }
        ]
      }
    }
  ],
  "评分标准": {
    "目标具体": "目标是否具体可量化",
    "策略有效性": "策略是否可行且有杠杆点",
    "数据驱动": "是否有数据分析支撑",
    "资源匹配": "预算和人力是否匹配"
  }
}
