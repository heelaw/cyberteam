{
  "skill_name": "exposure-click-conversion-analyzer",
  "测试案例": [
    {
      "id": "eval-1",
      "难度": "medium",
      "案例": "某在线课程产品，抖音信息流投放效果不佳需要分析",
      "输入": {
        "funnel_data": {
          "曝光": 100000,
          "点击": 2000,
          "转化": 20
        },
        "conversion_path": [
          "抖音信息流曝光",
          "用户点击进入落地页",
          "浏览课程详情",
          "点击购买按钮",
          "完成支付"
        ],
        "industry_benchmark": "学习类APP下载转化率1%-1.5%",
        "channel_type": "抖音信息流"
      },
      "预期输出": {
        "funnel_analysis": {
          "overall_conversion_rate": "0.02%",
          "曝光_to_点击": {
            "conversion_rate": "2%",
            "benchmark": "参考抖音信息流平均",
            "status": "normal"
          },
          "点击_to_转化": {
            "conversion_rate": "1%",
            "benchmark": "1%-1.5%",
            "status": "warning"
          }
        },
        "bottleneck_identification": {
          "weakest_step": "点击-转化环节",
