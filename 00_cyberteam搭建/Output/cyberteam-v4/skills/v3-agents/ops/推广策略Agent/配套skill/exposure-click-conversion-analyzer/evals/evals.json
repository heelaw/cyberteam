          }
        },
        "optimization_recommendations": [
          {
            "strategy": "缩短流程",
            "target_step": "浏览-购买",
            "expected_improvement": "减少20%流失",
            "implementation": "优化落地页，减少中间步骤"
          },
          {
            "strategy": "提升转化率",
            "target_step": "落地页",
            "expected_improvement": "提升50%",
            "implementation": "优化课程详情页，增加用户评价和效果展示"
          }
        ]
      }
    },
    {
      "id": "eval-2",
