{
  "skill_name": "KANO模型",
  "version": "v1.0",
  "eval_date": "2026-03-19",
  "test_cases": [
    {
      "case_id": "eval_001",
      "case_name": "笔记App基础功能分类",
      "difficulty": "simple",
      "scenario": {
        "用户输入": "一个笔记App有5个功能，怎么用KANO模型分类优先级"
      },
      "expected_output": {
        "需求列表": "5个功能的完整列表",
        "必须包含": [
          "KANO五类需求的完整定义",
          "每个功能的KANO分类",
          "优先级排序",
          "简要分析逻辑"
        ]
      },
      "evaluation_criteria": [
        "分类是否合理",
        "分析方法是否正确",
        "优先级是否明确"
      ]
    },
    {
      "case_id": "eval_002",
      "case_name": "企业协作工具功能优先级",
      "difficulty": "medium",
      "scenario": {
        "用户输入": "企业协作SaaS工具，需要同时满足管理者和员工两类用户的KANO分析"
      },
      "expected_output": {
        "双视角": "管理者视角 + 员工视角",
        "必须包含": [
          "两类用户的KANO分类差异对比",
          "冲突需求识别",
          "平衡策略建议",
          "分角色优先级"
        ]
      },
      "evaluation_criteria": [
        "是否区分两类用户不同",
        "是否识别出矛盾需求",
        "是否有平衡策略"
      ]
    },
    {
      "case_id": "eval_003",
      "case_name": "智能硬件产品KANO+路线图",
      "difficulty": "hard",
      "scenario": {
        "用户输入": "一款智能手表有30+功能，需要KANO分析并制定2年的产品规划"
      },
      "expected_output": {
        "完整分析": "30+功能的KANO分类",
        "必须包含": [
          "功能分组（基础/进阶/创新）",
          "KANO矩阵可视化",
          "分阶段路线图（Q1-Q8）",
          "资源约束下的优先级决策",
          "竞品对标分析",
          "动态审视（哪些A会变O）"
        ]
      },
      "evaluation_criteria": [
        "是否覆盖所有功能",
        "路线图是否可执行",
        "是否考虑需求动态演变"
      ]
    }
  ]
}
