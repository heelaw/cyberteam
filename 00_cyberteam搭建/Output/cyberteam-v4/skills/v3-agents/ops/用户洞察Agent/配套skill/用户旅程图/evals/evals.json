{
  "skill_name": "用户旅程图",
  "version": "v1.0",
  "eval_date": "2026-03-19",
  "test_cases": [
    {
      "case_id": "eval_001",
      "case_name": "咖啡点单小程序旅程分析",
      "difficulty": "simple",
      "scenario": {
        "用户输入": "分析用户使用咖啡点单小程序的旅程，找出优化点"
      },
      "expected_output": {
        "阶段划分": "4-6个阶段",
        "必须包含": [
          "各阶段的完整五要素",
          "情绪变化趋势",
          "至少2个具体痛点",
          "优化建议和优先级"
        ]
      },
      "evaluation_criteria": [
        "阶段是否覆盖完整",
        "痛点是否具体",
        "建议是否可落地"
      ]
    },
    {
      "case_id": "eval_002",
      "case_name": "在线教育App学习旅程",
      "difficulty": "medium",
      "scenario": {
        "用户输入": "分析用户从发现课程到完成学习的完整旅程，重点提升完课率"
      },
      "expected_output": {
        "阶段划分": "5-7个阶段",
        "必须包含": [
          "各阶段完整分析",
          "情绪曲线图示",
          "关键流失节点",
          "影响完课率的核心痛点",
          "提升完课率的建议"
        ]
      },
      "evaluation_criteria": [
        "是否体现在线学习特点",
        "流失节点是否有数据",
        "建议是否可执行"
      ]
    },
    {
      "case_id": "eval_003",
      "case_name": "B2B采购平台企业用户旅程",
      "difficulty": "hard",
      "scenario": {
        "用户输入": "分析企业用户从注册到完成首次采购的旅程，优化采购转化"
      },
      "expected_output": {
        "阶段划分": "6-8个阶段",
        "必须包含": [
          "决策者+使用者双重视角",
          "企业采购的特殊阶段（如审批）",
          "多角色触点分析",
          "B端信任建立要素",
          "完整的优化方案和优先级"
        ]
      },
      "evaluation_criteria": [
        "是否体现B端采购特殊性",
        "是否覆盖不同决策人",
        "方案是否可转化为产品需求"
      ]
    }
  ]
}
