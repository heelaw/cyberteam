{
  "skill_name": "场景判断器",
  "version": "1.0.0",
  "evals": [
    {
      "id": 1,
      "difficulty": "simple",
      "name": "朋友圈文案场景判断",
      "prompt": "请判断以下文案的场景并给出策略建议：\n\n## 文案信息\n- 发布渠道：微信朋友圈\n- 内容主题：在线文档工具促销\n- 目标用户：企业团队管理者\n\n请判断场景类型并给出内容策略",
      "expected_output": "场景类型、时间预估、内容策略建议",
      "files": [],
      "assertions": [
        {
          "type": "contains",
          "field": "场景类型",
          "expected": "短场景"
        },
        {
          "type": "contains",
          "field": "内容策略",
          "expected": "精简"
        }
      ]
    },
    {
      "id": 2,
      "difficulty": "medium",
      "name": "多场景覆盖方案制定",
      "prompt": "请为以下产品制定多场景覆盖方案：\n\n## 产品信息\n- 产品类型：B2B协作SaaS\n- 目标用户：中小企业管理者\n- 主要卖点：提升团队协作效率\n\n请分析不同场景并给出差异化策略",
      "expected_output": "短/中/长场景分析、多场景覆盖方案",
      "files": [],
      "assertions": [
        {
          "type": "contains",
          "field": "短场景",
          "expected": "朋友圈"
        },
        {
          "type": "contains",
          "field": "长场景",
          "expected": "官网"
        }
      ]
    }
  ],
  "version_history": [
