{
  "skill_name": "用户进群引导三步法",
  "version": "1.0",
  "eval_type": "skill_functional",
  "test_cases": [
    {
      "id": 1,
      "difficulty": "simple",
      "category": "免费社群",
      "input": {
        "scenario": "用户申请加入免费的北京健身爱好者社群，社群主要组织周末线下活动和每日打卡"
      },
      "expected_output": {
        "must_include": [
          "告知定位话术",
          "规则说明话术",
          "确认机制",
          "入群后欢迎引导"
        ],
        "output_structure": "三步流程+欢迎引导",
        "min_score": 3
      },
      "evaluation_criteria": {
        "feasibility": "是否可执行",
        "clarity": "话术是否清晰",
        "completeness": "流程是否完整"
      }
    },
    {
      "id": 2,
      "difficulty": "medium",
      "category": "付费社群",
      "input": {
        "scenario": "用户刚完成199元付费，需要引导加入产品经理学习社群，社群提供每周直播分享、群内答疑、一对一咨询"
      },
      "expected_output": {
        "must_include": [
          "告知社群价值",
          "说明服务内容",
          "用户确认机制",
          "入群欢迎语",
          "融入引导"
        ],
        "output_structure": "完整三步+增值服务引导",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "流程是否完整",
        "professionalism": "话术是否专业有温度",
        "value_emphasis": "是否强调付费价值"
      }
    },
    {
      "id": 3,
      "difficulty": "hard",
      "category": "高端社群",
      "input": {
        "scenario": "企业CEO高端社群，用户是知名企业创始人，需要设计差异化引导流程，体现专属感"
      },
      "expected_output": {
        "must_include": [
          "专属感设计",
          "一对一引导",
          "高端权益说明",
          "确认机制",
          "个性化欢迎",
          "融入计划"
        ],
        "output_structure": "高端定制引导流程",
        "min_score": 3
      },
      "evaluation_criteria": {
        "differentiation": "是否体现高端差异化",
        "feasibility": "方案是否可行",
        "professionalism": "是否体现专业与专属感"
      }
    }
  ],
  "evaluation_methodology": {
    "scoring": "每个维度1-5分，5分制评分",
    "pass_criteria": "总分≥15分（满分25分），且每个维度≥3分",
    "process": "1.告知定位 2.说明规则 3.获得确认 4.执行拉群 5.入群引导 6.跟进观察"
  },
  "coverage": {
    "场景覆盖": ["免费社群", "付费社群", "高端社群"],
    "难度分布": {
      "simple": 1,
      "medium": 1,
      "hard": 1
    }
  }
}
