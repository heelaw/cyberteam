{
  "skill_name": "早晚资讯三步法",
  "version": "1.0",
  "eval_type": "skill_functional",
  "test_cases": [
    {
      "id": 1,
      "difficulty": "simple",
      "category": "健身打卡社群晚报",
      "input": {
        "scenario": "你负责一个100人的健身打卡社群，晚上的晚报需要总结今日打卡情况，分享健身知识"
      },
      "expected_output": {
        "must_include": [
          "打卡统计呈现",
          "健身知识分享",
          "互动引导",
          "次日预告"
        ],
        "output_structure": "完整晚报模板",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "内容是否完整",
        "engagement": "是否有激励作用",
        "clarity": "形式是否活泼"
      }
    },
    {
      "id": 2,
      "difficulty": "medium",
      "category": "产品经理社群早报",
      "input": {
        "scenario": "你负责一个500人的产品经理社群，需要每天早上9点发送早报，帮助产品经理了解行业动态"
      },
      "expected_output": {
        "must_include": [
          "信息来源渠道",
          "内容筛选标准",
          "早报结构设计",
          "互动引导"
        ],
        "output_structure": "完整早报模板+方法论",
        "min_score": 3
      },
      "evaluation_criteria": {
        "feasibility": "是否可执行",
        "professionalism": "内容是否有专业见解",
        "value": "是否有信息价值"
      }
    },
    {
      "id": 3,
      "difficulty": "hard",
      "category": "多类型资讯整合",
      "input": {
        "scenario": "你负责一个综合型行业社群，需要同时提供早报（行业资讯）、午间分享（专家观点）、晚报（当日总结），如何设计资讯体系"
      },
      "expected_output": {
        "must_include": [
          "资讯类型分类",
          "不同时段内容规划",
          "质量控制方法",
          "团队分工安排",
          "效果评估体系"
        ],
        "output_structure": "完整资讯运营体系",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "体系是否完整",
        "feasibility": "是否可执行",
        "scalability": "是否可扩展"
      }
    }
  ],
  "evaluation_methodology": {
    "scoring": "每个维度1-5分，5分制评分",
    "pass_criteria": "总分≥15分（满分25分），且每个维度≥3分",
    "process": "1.信息收集 2.信息整合 3.信息输出 4.互动引导 5.复盘优化"
  },
  "coverage": {
    "场景覆盖": ["早报", "晚报", "综合资讯"],
    "难度分布": {
      "simple": 1,
      "medium": 1,
      "hard": 1
    }
  }
}
