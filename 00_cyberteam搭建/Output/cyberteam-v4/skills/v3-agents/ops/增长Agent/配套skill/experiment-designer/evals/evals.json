{
  "skill_name": "experiment-designer",
  "version": "1.0.0",
  "evals": [
    {
      "id": "eval-0",
      "difficulty": "simple",
      "title": "简单场景：单一产品功能优化",
      "description": "对单一功能的优化实验进行设计和评估",
      "context": {
        "product": "某在线教育平台的课程详情页",
        "goal": "提升课程购买转化率",
        "experiments": [
          {
            "name": "课程价格隐藏",
            "hypothesis": "隐藏课程原价只显示优惠价可以提升购买转化率",
            "reason": "价格是用户决策的重要障碍"
          }
        ]
      },
      "expected_output": {
        "steps": [
          {
            "step": 1,
            "name": "收集实验想法",
            "expected": "列出1个实验想法及核心假设"
          },
          {
            "step": 2,
            "name": "ICE评分",
            "expected": "完成ICE三维度评分并计算总分"
          },
          {
            "step": 3,
            "name": "实验方案设计",
            "expected": "包含样本量、周期、对照组、指标设计"
          },
          {
            "step": 4,
            "name": "风险分析",
            "expected": "识别至少3个风险并给出应对策略"
          },
          {
            "step": 5,
            "name": "执行计划",
            "expected": "包含排期、成功指标、行动项"
          }
        ],
        "quality_requirements": {
          "ice_completeness": "100%",
          "design_completeness": "100%",
          "risk_identification": ">=3",
          "priority_ranking": "正确"
        }
      },
      "success_criteria": [
        "ICE评分完整（I、C、E三个维度）",
        "实验设计方案包含所有必要参数",
        "风险识别>=3个",
        "输出完整的执行计划"
      ]
    },
    {
      "id": "eval-1",
      "difficulty": "medium",
      "title": "中等场景：多个实验想法排序",
      "description": "对3个实验想法进行ICE评分和优先级排序",
      "context": {
        "product": "某电商App",
        "goal": "提升用户下单转化率",
        "experiments": [
          {
            "name": "购物车页优化",
            "hypothesis": "优化购物车页面布局可以提升结算转化",
            "reason": "购物车是下单前最后一环"
          },
          {
            "name": "限时优惠倒计时",
            "hypothesis": "限时优惠倒计时可以提升用户紧迫感，促进下单",
            "reason": "损失厌恶心理"
          },
          {
            "name": "会员免运费",
            "hypothesis": "会员免运费可以提升客单价和下单率",
            "reason": "运费是影响下单的重要因素"
          }
        ]
      },
      "expected_output": {
        "steps": [
          {
            "step": 1,
            "name": "收集实验想法",
            "expected": "列出3个实验想法及核心假设"
          },
          {
            "step": 2,
            "name": "ICE评分",
            "expected": "完成3个实验的ICE三维度评分，计算总分并排序",
            "ice_expected": {
              "购物车页优化": {
                "impact": 7,
                "confidence": 9,
                "ease": 8,
                "total": 504
              },
              "限时优惠倒计时": {
                "impact": 8,
                "confidence": 7,
                "ease": 7,
                "total": 392
              },
              "会员免运费": {
                "impact": 9,
                "confidence": 6,
                "ease": 5,
                "total": 270
              }
            }
          },
          {
            "step": 3,
            "name": "实验方案设计",
            "expected": "为排名第一的实验设计完整方案",
            "design_expected": {
              "sample_size": "基于转化率计算",
              "period": "7-14天",
              "control_group": "现有购物车页面",
              "experiment_group": "优化版购物车页面",
              "metrics": {
                "core": "结算转化率",
                "auxiliary": "页面浏览量、点击率",
                "guardrail": "客服投诉率"
              }
            }
          },
          {
            "step": 4,
            "name": "风险分析",
            "expected": "识别技术、业务、数据风险并给出应对策略",
            "risks_expected": [
              "技术风险：页面加载性能影响",
              "业务风险：优惠券使用率监控",
              "数据风险：归因准确性"
            ]
          },
          {
            "step": 5,
            "name": "执行计划",
            "expected": "包含详细排期、指标定义、下一步行动"
          }
        ],
        "quality_requirements": {
          "ice_completeness": "100%",
          "design_completeness": "100%",
          "risk_identification": ">=3",
          "priority_ranking": "正确（购物车>限时优惠>免运费）"
        }
      },
      "success_criteria": [
        "ICE评分完整，每个实验都有I、C、E评分",
        "正确排序：购物车页优化(504)>限时优惠(392)>会员免运费(270)",
        "实验设计方案包含样本量、周期、对照组、指标",
        "风险识别>=3个，包含应对策略",
        "输出完整的执行计划"
      ]
    },
    {
      "id": "eval-2",
      "difficulty": "complex",
      "title": "复杂场景：增长实验组合设计",
      "description": "对5个增长实验想法进行综合评估，包括ICE评分、实验设计和风险分析",
      "context": {
        "product": "某增长中的互联网产品（月活100万）",
        "goal": "提升用户留存和活跃度",
        "experiments": [
          {
            "name": "新用户引导流程优化",
            "hypothesis": "简化新用户引导流程可以提升7日留存",
            "reason": "首周是用户习惯养成的关键期"
          },
          {
            "name": "签到打卡奖励",
            "hypothesis": "签到奖励可以提升用户活跃度",
            "reason": "游戏化机制可以提升粘性"
          },
          {
            "name": "Push通知优化",
            "hypothesis": "优化Push推送策略可以提升用户召回率",
            "reason": "Push是重要的召回渠道"
          },
          {
            "name": "个性化推荐",
            "hypothesis": "个性化推荐可以提升内容消费时长",
            "reason": "匹配用户需求的内容更易被消费"
          },
          {
            "name": "社交分享激励",
            "hypothesis": "社交分享奖励可以提升用户裂变",
            "reason": "社交传播是低成本获客渠道"
          }
        ],
        "constraints": {
          "concurrent_experiments": 2,
          "engineering_resources": "1个研发团队",
          "timeline": "Q2季度"
        }
      },
      "expected_output": {
        "steps": [
          {
            "step": 1,
            "name": "收集实验想法",
            "expected": "列出5个实验想法，包含用户漏斗层级"
          },
          {
            "step": 2,
            "name": "ICE评分",
            "expected": "完成5个实验的ICE评分并排序",
            "ice_expected": {
              "新用户引导": {
                "impact": 8,
                "confidence": 8,
                "ease": 7,
                "total": 448
              },
              "签到奖励": {
                "impact": 7,
                "confidence": 7,
                "ease": 9,
                "total": 441
              },
              "Push优化": {
                "impact": 6,
                "confidence": 8,
                "ease": 8,
                "total": 384
              },
              "个性化推荐": {
                "impact": 9,
                "confidence": 5,
                "ease": 4,
                "total": 180
              },
              "社交分享": {
                "impact": 7,
                "confidence": 6,
                "ease": 6,
                "total": 252
              }
            }
          },
          {
            "step": 3,
            "name": "实验方案设计",
            "expected": "为Top 2实验设计完整方案（考虑并发限制）",
            "design_expected": [
              {
                "experiment": "新用户引导优化",
                "sample_size": "每组至少5000新用户",
                "period": "14天",
                "metrics": {
                  "core": "7日留存率",
                  "auxiliary": "引导完成率",
                  "guardrail": "卸载率"
                }
              },
              {
                "experiment": "签到奖励",
                "sample_size": "每组10000活跃用户",
                "period": "7天",
                "metrics": {
                  "core": "DAU",
                  "auxiliary": "签到率",
                  "guardrail": "成本"
                }
              }
            ]
          },
          {
            "step": 4,
            "name": "风险分析",
            "expected": "识别多个风险，考虑实验间相互影响",
            "risks_expected": [
              "技术风险：新用户引导可能影响性能",
              "业务风险：签到奖励成本控制",
              "数据风险：留存归因准确性",
              "依赖风险：两个实验间用户重叠",
              "资源风险：研发资源分配"
            ]
          },
          {
            "step": 5,
            "name": "执行计划",
            "expected": "考虑资源约束的排期，详细的成功指标",
            "plan_expected": {
              "timeline": "按优先级排期，Top 2先执行",
              "success_criteria": "具体可量化",
              "next_actions": "清晰的行动项"
            }
          }
        ],
        "quality_requirements": {
          "ice_completeness": "100%",
          "design_completeness": "100%",
          "risk_identification": ">=5（考虑资源约束）",
          "priority_ranking": "正确（考虑并发限制）",
          "resource_awareness": "考虑2个并发实验限制"
        }
      },
      "success_criteria": [
        "ICE评分完整，5个实验都有I、C、E评分",
        "正确排序：新用户引导(448)>签到奖励(441)>Push优化(384)>社交分享(252)>个性化推荐(180)",
        "实验设计考虑并发限制，只对Top 2设计详细方案",
        "风险识别>=5个，包含实验间依赖和资源约束",
        "输出考虑资源约束的执行计划"
      ]
    }
  ],
  "version_history": [
    {
      "version": "1.0.0",
      "date": "2026-03-17",
      "changes": "初始版本"
    }
  ]
