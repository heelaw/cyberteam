        "timeline": "2年",
        "metrics": {
          "客户数": 100,
          "ARPU": 50000,
          "续费率": 0.7,
          "获客成本": 30000
        },
        "budget": 800,
        "team_size": 15
      },
      "expected_output": {
        "focus": "以获客效率和续费率提升为主",
        "hypothesis_count": "2-4个",
        "key_metrics": ["LTV/CAC", "续费率", "获客成本"]
      }
    },
    {
      "id": "3",
      "scenario": "在线教育平台增长规划",
      "description": "一家在线教育平台，月收入100万，需要规划增长",
      "difficulty": "medium",
      "input": {
        "current_revenue": 100,
        "target_revenue": 500,
        "timeline": "1年",
        "metrics": {
          "月流量": 500000,
          "转化率": 0.03,
          "客单价": 7000,
          "完课率": 0.3
        },
        "budget": 300,
        "team_size": 10
      },
      "expected_output": {
        "focus": "转化率提升空间最大",
        "primary_strategy": "优化转化流程",
        "hypothesis_count": "2-3个"
