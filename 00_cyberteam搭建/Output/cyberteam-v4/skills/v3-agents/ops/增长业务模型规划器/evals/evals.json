{
  "version": "1.1",
  "test_cases": [
    {
      "id": "1",
      "scenario": "电商平台增长规划",
      "description": "一家年营收1000万的电商平台，希望规划未来1年实现5倍增长（从1000万到5000万）",
      "difficulty": "hard",
      "input": {
        "current_revenue": 1000,
        "target_revenue": 5000,
        "timeline": "1年",
        "metrics": {
          "月流量": 100000,
          "转化率": 0.02,
          "客单价": 500,
          "复购率": 0.2
        },
        "budget": 500,
        "team_size": 20
      },
      "expected_output": {
        "growth_hypothesis": [
          {
            "id": "1",
            "hypothesis": "通过渠道A实现流量3倍增长",
            "evidence": "历史数据支持该渠道ROI最高",
            "verification_method": "A/B测试",
            "investment": 150,
            "expected_return": "流量从10万到30万"
          }
        ],
        "growth_path": {
          "phase_1": {
            "timeline": "Q1",
            "focus": "渠道深耕",
            "key_actions": ["优化投放ROI", "内容营销"]
          },
          "phase_2": {
            "timeline": "Q2-Q4",
            "focus": "渠道扩展",
            "key_actions": ["新渠道测试", "社交裂变"]
          }
        },
        "risk_coverage": ["流量成本上升", "竞争加剧"],
        "hypothesis_count": "3-5个假设"
      },
      "evaluation_points": [
        "增长假设清晰可验证",
        "增长路径设计合理",
        "风险识别准确",
        "策略可落地"
      ]
    },
    {
      "id": "2",
      "scenario": "SaaS产品增长规划",
      "description": "一家B2B SaaS公司，年收入500万，需要规划增长路径",
