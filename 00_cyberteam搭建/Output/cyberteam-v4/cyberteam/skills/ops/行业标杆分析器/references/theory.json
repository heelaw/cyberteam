{
  "version": "1.0",
  "core_theory": {
    "name": "行业标杆分析",
    "source": "业务操盘手课程 - 第三章：跨界借鉴模型",
    "summary": "通过多维度深度分析标杆企业，提取可迁移的业务要素",
    "key_principle": "分析成功背后的底层逻辑，区分可迁移要素和独特要素"
  },
  "analysis_dimensions": [
    {
      "dimension": "商业模型",
      "questions": [
        "如何创造价值？",
        "为谁创造价值？",
        "如何传递价值？"
      ],
      "outputs": ["价值主张", "目标用户", "产品服务", "渠道"]
    },
    {
      "dimension": "增长策略",
      "questions": [
        "如何获取用户？",
        "如何激活用户？",
        "如何留存用户？",
        "如何变现？"
      ],
      "outputs": ["获客策略", "激活策略", "留存策略", "变现模式"]
    },
    {
      "dimension": "运营体系",
      "questions": [
        "如何保障业务运转？",
        "关键流程是什么？",
        "团队如何分工？"
      ],
      "outputs": ["业务流程", "运营机制", "组织架构"]
    },
    {
      "dimension": "核心壁垒",
      "questions": [
        "为什么能持续成功？",
        "竞争对手难以复制什么？"
      ],
      "outputs": ["品牌壁垒", "数据壁垒", "网络效应", "规模效应"]
    },
    {
      "dimension": "财务模型",
      "questions": [
        "如何盈利？",
        "收入来源是什么？",
        "成本结构如何？"
      ],
      "outputs": ["收入结构", "成本结构", "盈利模式", "单位经济"]
    }
  ],
  "element_classification": [
    {
      "type": "可迁移要素",
      "description": "底层逻辑和方法论，可以迁移到其他场景",
      "examples": ["增长飞轮", "用户分层运营", "数据驱动决策"]
    },
    {
      "type": "独特要素",
      "description": "与特定资源或能力相关，需要调整适配",
      "examples": ["特定内容IP", "独有数据", "特殊关系"]
    },
    {
      "type": "壁垒要素",
      "description": "难以复制或需要长期积累",
      "examples": ["品牌认知", "网络效应", "规模优势"]
    }
  ],
  "references": [
    {"name": "跨界借鉴四步法", "source": "业务操盘手课程 - 第三章"},
    {"name": "标杆案例分析", "source": "业务操盘手课程 - 第三章"}
  ]
}
