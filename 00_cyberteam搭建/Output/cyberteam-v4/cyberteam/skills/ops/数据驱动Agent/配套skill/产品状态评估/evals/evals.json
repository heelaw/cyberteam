          "DAU/MAU偏低，用户粘性不足",
          "功能渗透率待提升",
          "复购数据需持续观察"
        ],
        "建议": [
          "P0: 优化核心功能体验",
          "P1: 建设用户激励体系",
          "P2: 持续监控关键指标"
        ]
      },
      "evaluation_criteria": [
