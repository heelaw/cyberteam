{
  "skill_name": "user-lifecycle-manager",
  "测试案例": [
    {
      "id": "eval-1",
      "难度": "medium",
      "案例": "某在线教育平台需要管理用户全生命周期，提升用户LTV",
      "输入": {
        "user_data": {"用户阶段分布": "新用户40%，成长30%，成熟20%，沉默8%，流失2%"},
        "product_stage": "成长期"
      },
      "预期输出": {
        "lifecycle_stages": [
          {"stage": "拉新期", "duration": "0-7天", "key_metrics": ["注册率", "首单转化率"], "typical_behaviors": ["注册账号", "完成首购", "首次上课"]},
          {"stage": "成长期", "duration": "7-30天", "key_metrics": ["活跃率", "完课率", "作业提交率"], "typical_behaviors": ["持续学习", "参与互动", "完成阶段性目标"]},
          {"stage": "成熟期", "duration": "30-180天", "key_metrics": ["续费率", "推荐率", "交叉购买率"], "typical_behaviors": ["稳定学习", "口碑传播", "购买更多课程"]},
          {"stage": "沉默期", "duration": "180-365天", "key_metrics": ["沉默率", "唤醒成功率"], "typical_behaviors": ["登录减少", "不参与活动", "无续费意向"]},
          {"stage": "流失期", "duration": ">365天", "key_metrics": ["流失率", "挽回成本"], "typical_behaviors": ["长期不登录", "明确表示离开"]}
        ],
        "stage_strategies": {
          "拉新期": {"target": "快速完成首单转化", "actions": ["新用户专属优惠", "1对1班主任引导", "首单返现"], "success_criteria": "首单转化率>30%"},
          "成长期": {"target": "建立学习习惯", "actions": ["学习计划推送", "作业提醒", "同伴激励", "阶段性测试"], "success_criteria": "完课率>60%"},
          "成熟期": {"target": "提升LTV和推荐", "actions": ["续费优惠", "高等级权益", "推荐奖励", "高阶课程推荐"], "success_criteria": "续费率>50%"},
          "沉默期": {"target": "唤醒沉睡用户", "actions": ["定向推送", "专属召回优惠", "流失预警触达"], "success_criteria": "唤醒率>20%"},
          "流失期": {"target": "挽回或沉淀", "actions": ["深度访谈了解原因", "大额优惠挽留", "标记为流失提供对照"], "success_criteria": "挽回率>5%"}
        },
        "transition_management": {
          "拉新→成长": {"触发条件": "完成首次购买和学习", "干预动作": "立即进入成长体系"},
          "成长→成熟": {"触发条件": "学习时长>30小时或完课>3门", "干预动作": "推送高阶课程和续费优惠"},
          "成熟→沉默": {"触发条件": "30天无登录或无学习行为", "干预动作": "触发沉默预警，立即启动唤醒流程"},
          "沉默→流失": {"触发条件": "60天无登录", "干预动作": "最后一次召回，无效则标记流失"}
        }
      }
    }
  ],
  "评分标准": {
    "阶段完整性": "是否覆盖完整生命周期且定义清晰",
    "策略针对性": "每阶段策略是否有针对性",
    "过渡管理": "是否有跨阶段识别和干预机制",
    "可衡量": "指标是否可追踪，效果是否可量化"
  }
}
