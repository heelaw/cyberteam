{
  "skill_name": "具体问题全局化",
  "version": "1.0",
  "created": "2026-03-20",
  "updated": "2026-03-20",
  "assessment_dimensions": [
    {
      "dimension": "完整性",
      "weight": 0.20,
      "description": "全局化思考是否覆盖所有必要维度",
      "criteria": [
        {
          "id": "C1",
          "description": "目的追问链条完整",
          "levels": {
            "excellent": "连续追问3-5个为什么直到根本目的，用户明确表达核心目的",
            "good": "追问链条基本完整",
            "acceptable": "追问深度有限",
            "poor": "没有追问或追问过浅"
          }
        },
        {
          "id": "C2",
          "description": "四个维度覆盖完整",
          "levels": {
            "excellent": "目的/角色/时间/资源四个维度全部覆盖且分析深入",
            "good": "四个维度基本覆盖",
            "acceptable": "部分维度覆盖不全",
            "poor": "维度缺失严重"
          }
        },
        {
          "id": "C3",
          "description": "有具体行动方案产出",
          "levels": {
            "excellent": "综合四个维度产出完整的具体行动方案",
            "good": "有行动方案但不完整",
            "acceptable": "行动方案较为笼统",
            "poor": "没有行动方案"
          }
        }
      ]
    },
    {
      "dimension": "实用性",
      "weight": 0.20,
      "description": "全局化结果是否能指导实践",
      "criteria": [
        {
          "id": "P1",
          "description": "能帮助用户跳出问题本身",
          "levels": {
            "excellent": "完全帮助用户跳出具体问题，看到更广阔视角",
            "good": "基本帮助用户跳出问题",
            "acceptable": "有一定跳出但不够彻底",
            "poor": "用户仍然陷在具体问题中"
          }
        },
        {
          "id": "P2",
          "description": "行动方案可执行",
          "levels": {
            "excellent": "行动方案具体明确，可直接执行",
            "good": "行动方案基本可执行",
            "acceptable": "行动方案需要进一步细化",
            "poor": "行动方案过于理论化"
          }
        },
        {
          "id": "P3",
          "description": "优先级清晰",
          "levels": {
            "excellent": "行动有明确的优先级排序和依据",
            "good": "有优先级标注",
            "acceptable": "优先级不够清晰",
            "poor": "没有优先级"
          }
        }
      ]
    },
    {
      "dimension": "专业性",
      "weight": 0.20,
      "description": "全局化方法是否专业",
      "criteria": [
        {
          "id": "S1",
          "description": "角色转换成功",
          "levels": {
            "excellent": "用户成功切换到更高层级视角，识别出视角差异",
            "good": "角色转换基本成功",
            "acceptable": "角色转换有限",
            "poor": "角色转换失败"
          }
        },
        {
          "id": "S2",
          "description": "时间维度分析到位",
          "levels": {
            "excellent": "覆盖过去/现在/未来，对趋势判断明确，影响分析深入",
            "good": "时间维度基本覆盖",
            "acceptable": "时间维度分析较浅",
            "poor": "缺少时间维度"
          }
        },
        {
          "id": "S3",
          "description": "资源视角分析深入",
          "levels": {
            "excellent": "资源盘点完整（人力/财务/信息/关系），约束明确，配置方案合理",
            "good": "资源视角基本覆盖",
            "acceptable": "资源分析较浅",
            "poor": "缺少资源视角"
          }
        }
      ]
    },
    {
      "dimension": "严谨性",
      "weight": 0.20,
      "description": "过程是否严谨规范",
      "criteria": [
        {
          "id": "R1",
          "description": "先认可再引导",
          "levels": {
            "excellent": "完全没有否定具体问题的价值，引导自然",
            "good": "基本做到先认可",
            "acceptable": "认可较为表面",
            "poor": "直接否定用户问题"
          }
        },
        {
          "id": "R2",
          "description": "四步完整执行",
          "levels": {
            "excellent": "没有跳过任何步骤，逻辑递进清晰",
            "good": "步骤基本完整",
            "acceptable": "部分步骤简化",
            "poor": "缺少关键步骤"
          }
        },
        {
          "id": "R3",
          "description": "追问而非给答案",
          "levels": {
            "excellent": "完全通过追问引导，用户自己得出结论",
            "good": "基本使用追问引导",
            "acceptable": "追问与告知参半",
            "poor": "直接告知结论"
          }
        }
      ]
    },
    {
      "dimension": "独特个性",
      "weight": 0.10,
      "description": "是否有独特价值",
      "criteria": [
        {
          "id": "U1",
          "description": "能发现原视角盲区",
          "levels": {
            "excellent": "发现了原视角下明显忽略的关键问题",
            "good": "发现了一些盲区",
            "acceptable": "盲区发现有限",
            "poor": "没有发现盲区"
          }
        },
        {
          "id": "U2",
          "description": "提供差异化视角",
          "levels": {
            "excellent": "提供独特而有价值的全局视角",
            "good": "有一定差异化",
            "acceptable": "视角较为通用",
            "poor": "无差异化"
          }
        }
      ]
    },
    {
      "dimension": "规范性",
      "weight": 0.10,
      "description": "输出格式是否规范",
      "criteria": [
        {
          "id": "N1",
          "description": "使用标准输出模板",
          "levels": {
            "excellent": "完全按照模板格式输出",
            "good": "基本按照模板格式",
            "acceptable": "格式基本规范",
            "poor": "格式混乱"
          }
        },
        {
          "id": "N2",
          "description": "过程记录清晰",
          "levels": {
            "excellent": "四步过程完整记录，可追溯",
            "good": "过程记录基本完整",
            "acceptable": "记录有缺失",
            "poor": "没有记录"
          }
        }
      ]
    }
  ],
  "scoring_guide": {
    "excellent": 5,
    "good": 4,
    "acceptable": 3,
    "poor": 1
  },
  "pass_threshold": 85,
  "max_score": 100,
  "calculation_method": "各维度得分乘以权重后累加，满分100分"
}
