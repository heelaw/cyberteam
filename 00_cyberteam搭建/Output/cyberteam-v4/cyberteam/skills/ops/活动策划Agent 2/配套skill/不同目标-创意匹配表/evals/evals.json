{
  "skill_name": "不同目标-创意匹配表",
  "version": "1.0.0",
  "eval_date": "2026-03-19",
  "test_cases": [
    {
      "case_id": "eval_001",
      "case_name": "拉新目标匹配分析",
      "difficulty": "medium",
      "scenario": {
        "业务问题": "平台用户增长停滞，需要获取新用户扩大规模",
        "活动定位": "短期拉新为主，配合品牌曝光",
        "约束条件": "预算100万，时间30天"
      },
      "expected_output": {
        "目标拆解": {
          "核心目标": "获取新用户10万人",
          "辅助目标": "品牌曝光、建立认知"
        },
        "KPI矩阵": [
          {"指标": "新用户数", "类型": "结果指标", "权重": "60%"},
          {"指标": "注册转化率", "类型": "过程指标", "权重": "20%"},
          {"指标": "获客成本", "类型": "效率指标", "权重": "20%"}
        ],
        "匹配度分析": {
          "推荐创意类型": [
            {
              "类型": "福利驱动型",
              "匹配度": "5星",
              "理由": "直接用利益激励新用户注册，效果显著，适合拉新目标"
            },
            {
              "类型": "社交裂变型",
              "匹配度": "4星",
              "理由": "通过社交网络实现病毒传播，成本低，适合扩大覆盖面"
            },
            {
              "类型": "限时稀缺型",
              "匹配度": "3星",
              "理由": "制造紧迫感可推动决策，但拉新效果不如福利型直接"
            }
          ],
          "不推荐类型": [
            {
              "类型": "游戏化型",
              "理由": "游戏化适合长期促活和留存，短期拉新效果不明显"
            },
            {
              "类型": "话题互动型",
              "理由": "话题传播适合品牌曝光，拉新转化链路太长"
            }
          ]
        },
        "最优策略": "福利驱动为主（1元购）+ 社交裂变为辅（邀请得红包），既能保证拉新效果，又能通过裂变扩大覆盖面",
        "受众适配": {
          "受众类型": "价格敏感新用户",
          "推荐创意": "福利驱动型",
          "激励偏好": "直接优惠（现金、实物）"
        },
        "注意事项": [
          "CAC要控制在10元以内",
          "要防止羊毛党",
          "新用户质量要关注"
        ]
      },
      "evaluation_criteria": [
        "匹配度评分是否有依据",
        "推荐理由是否充分",
        "组合策略是否合理"
      ]
    },
    {
      "case_id": "eval_002",
      "case_name": "促活目标匹配分析",
      "difficulty": "simple",
      "scenario": {
        "业务问题": "平台DAU低（5万），用户活跃度差，需要激活沉默用户",
        "活动定位": "促活为主，提升用户习惯",
        "约束条件": "预算50万，时间45天"
      },
      "expected_output": {
        "目标拆解": {
          "核心目标": "DAU从5万提升到10万",
          "辅助目标": "培养用户学习习惯，提升留存"
        },
        "KPI矩阵": [
          {"指标": "DAU", "类型": "结果指标", "权重": "50%"},
          {"指标": "日活率", "类型": "质量指标", "权重": "30%"},
          {"指标": "连续打卡率", "类型": "过程指标", "权重": "20%"}
        ],
        "匹配度分析": {
          "推荐创意类型": [
            {
              "类型": "竞赛排行型",
              "匹配度": "5星",
              "理由": "排行榜竞争机制能有效激发用户参与，适合促活"
            },
            {
              "类型": "游戏化型",
              "匹配度": "4星",
              "理由": "成长体系能培养用户习惯，长期促活效果好"
            },
            {
              "类型": "福利驱动型",
              "匹配度": "4星",
              "理由": "直接利益驱动，见效快，但可能培养不出用户习惯"
            }
          ],
          "不推荐类型": [
            {
              "类型": "话题互动型",
              "理由": "话题适合传播，不适合日常促活"
            }
          ]
        },
        "最优策略": "竞赛排行型（短期爆发）+ 游戏化型（长期养成），先用排行榜激发竞争，再用成长体系培养习惯",
        "受众适配": {
          "受众类型": "有学习需求但缺乏持续性的用户",
          "推荐创意": "竞赛排行型 + 游戏化型",
          "激励偏好": "竞争排名 + 成长成就"
        },
        "注意事项": [
          "防止刷登录（需完成实际学习）",
          "激励不能过度依赖福利",
          "要持续更新内容和任务"
        ]
      },
      "evaluation_criteria": [
        "目标与KPI对应是否清晰",
        "创意推荐是否合理",
        "受众分析是否准确"
      ]
    }
  ]
}
