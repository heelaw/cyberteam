{
  "version": "2.0",
  "test_cases": [
    {
      "id": "1",
      "scenario": "客服流程SOP优化",
      "description": "一家电商公司客服团队需要优化客服处理流程",
      "difficulty": "medium",
      "input": {
        "current_process": "用户反馈 → 客服接待 → 问题判断 → 处理/升级 → 回访",
        "issues": [
          "处理时间过长",
          "升级流程不清晰",
          "用户重复描述问题"
        ],
        "team_size": "10人"
      },
      "expected_output": {
        "sop_complete": true,
        "process_steps": "≤5步",
        "checkpoints": "有明确检查点",
        "efficiency_improvement": "≥20%"
      },
      "evaluation_points": [
        "问题识别是否准确",
        "SOP是否简洁可执行",
        "检查点是否设置合理",
        "升级机制是否清晰"
      ]
    },
    {
      "id": "2",
      "scenario": "项目复盘标准化",
      "description": "互联网公司项目团队需要建立标准化复盘流程",
      "difficulty": "medium",
      "input": {
        "project_context": "一个迭代周期为2周的项目团队，共8人",
        "current_issues": "复盘流于形式，经验无法沉淀",
        "desired_outcome": "建立可执行的复盘SOP"
      },
      "expected_output": {
        "retrospective_sop": "完整",
        "template": "可直接使用",
        "action_items": "有跟进机制"
      },
      "evaluation_points": [
        "复盘流程是否标准化",
        "模板是否可直接使用",
        "跟进机制是否有效"
      ]
    }
  ],
  "evaluation_criteria": {
    "process_clarity": "流程清晰、问题识别准确",
    "sop_executability": "SOP简洁实用、可直接执行",
    "checkpoints": "关键步骤有检查点",
    "escalation_clarity": "升级机制清晰",
    "efficiency_improvement": "效率提升明显"
  }
}
