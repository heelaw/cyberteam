          "流量增长目标",
          "转化率提升目标",
          "客单价提升目标",
          "复购率提升目标",
          "新产品上线目标"
        ],
        "metrics": "每个子目标有量化指标",
        "milestones": "有季度里程碑"
      },
      "evaluation_points": [
        "拆解符合MECE原则",
        "指标量化完整",
        "路径规划清晰"
      ]
    },
    {
