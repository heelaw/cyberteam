{
  "version": "1.0",
  "test_cases": [
    {
      "id": "1",
      "scenario": "季度销售目标执行计划",
      "description": "销售总监需要将季度销售目标转化为详细的执行计划",
      "difficulty": "medium",
      "input": {
        "goal": "季度GMV 1000万",
        "metrics": "新客获取500、复购率30%",
        "timeframe": "90天",
        "resources": {
          "team": "8人",
          "budget": "50万"
        }
      },
      "expected_output": {
        "tasks_complete": true,
        "task_count": "≥15项",
        "timeline_clear": true,
        "priorities_sorted": true,
        "risks_identified": true
      },
      "evaluation_points": [
        "任务是否覆盖目标的所有方面",
        "时间规划是否合理",
        "优先级是否正确",
        "资源配置是否匹配",
        "风险是否有预案"
      ]
    },
    {
      "id": "2",
      "scenario": "产品上线计划",
      "description": "产品经理需要制定新产品上线计划",
      "difficulty": "high",
      "input": {
        "goal": "新产品成功上线",
        "metrics": "首周DAU 10000",
        "timeframe": "60天",
        "resources": {
          "dev": "5人",
          "design": "2人",
          "budget": "30万"
        }
      },
      "expected_output": {
        "milestones": "≥3个关键里程碑",
        "tasks层级": "项目→里程碑→任务→子任务",
        "dependencies_clear": true,
        "risk_response": "有预案"
      },
      "evaluation_points": [
        "里程碑设置是否合理",
        "任务分解是否到位",
        "依赖关系是否清晰",
        "风险是否有应对"
      ]
    }
  ],
  "evaluation_criteria": {
    "task_completeness": "任务覆盖目标的所有方面",
    "timeline_quality": "时间安排合理、有缓冲",
    "priority_quality": "优先级划分正确",
    "resource_matching": "资源匹配合理",
    "risk_awareness": "风险识别全面"
  }
