{
  "skill_name": "UGC社区五步搭建法",
  "version": "1.0",
  "eval_type": "skill_functional",
  "test_cases": [
    {
      "id": 1,
      "difficulty": "simple",
      "category": "社群激活",
      "input": {
        "scenario": "500人摄影爱好者社群活跃度低，想重新激活"
      },
      "expected_output": {
        "must_include": ["现状诊断", "内容优化方案", "核心用户激励", "促活活动计划"],
        "output_structure": "诊断+方案+计划",
        "min_score": 3
      },
      "evaluation_criteria": {
        "diagnosis": "诊断是否准确",
        "feasibility": "方案是否可行",
        "clarity": "输出是否清晰"
      }
    },
    {
      "id": 2,
      "difficulty": "medium",
      "category": "社区搭建",
      "input": {
        "scenario": "搭建产品经理知识分享社区，有100个目标用户微信好友"
      },
      "expected_output": {
        "must_include": ["社区定位", "内容分类方案", "冷启动方案", "激励体系", "增长策略"],
        "output_structure": "五步完整方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "是否覆盖五步",
        "feasibility": "方案是否可行",
        "clarity": "输出是否清晰"
      }
    },
    {
      "id": 3,
      "difficulty": "hard",
      "category": "从0搭建",
      "input": {
        "scenario": "从0搭建AI创业者垂直社区，6个月做到1000活跃用户"
      },
      "expected_output": {
        "must_include": ["完整定位策略", "详细执行方案", "资源预算", "里程碑和验收标准", "风险应对预案"],
        "output_structure": "完整商业计划",
        "min_score": 3
      },
      "evaluation_criteria": {
        "strategic": "战略视角是否足够",
        "realistic": "目标是否可行",
        "comprehensive": "是否覆盖所有关键环节"
      }
    }
  ],
  "evaluation_methodology": {
    "scoring": "每个维度1-5分，5分制评分",
    "pass_criteria": "总分≥15分（满分25分），且每个维度≥3分",
    "process": "1.确定社区定位 2.设计内容分类 3.制定冷启动方案 4.设计激励体系 5.制定增长策略"
  }
}
