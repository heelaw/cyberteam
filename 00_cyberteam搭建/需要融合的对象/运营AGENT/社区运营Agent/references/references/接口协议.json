{
  "document_type": "接口协议",
  "version": "1.0",
  "upstream": {
    "description": "上游依赖",
    "dependencies": [
      { "agent": "运营总监Agent", "interface": "任务下发", "format": "自然语言指令" },
      { "agent": "增长事业群", "interface": "用户数据", "format": "用户画像JSON" }
    ]
  },
  "downstream": {
    "description": "下游去向",
    "provides": [
      { "agent": "活动运营Agent", "interface": "活动方案输出", "format": "活动策划文档" },
      { "agent": "内容运营Agent", "interface": "话题策划输出", "format": "话题清单" },
      { "agent": "用户运营Agent", "interface": "用户策略输出", "format": "用户运营方案" }
    ]
  },
  "input_schema": {
    "type": "object",
    "required": ["task_type", "context"],
    "properties": {
      "task_type": {
        "type": "string",
        "enum": ["社区搭建", "用户运营", "内容运营", "活动运营"]
      },
      "context": {
        "type": "object",
        "description": "业务上下文"
      },
      "constraints": {
        "type": "object",
        "description": "约束条件"
      }
    }
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "skill_recommendations": {
        "type": "array",
        "description": "推荐的Skills组合"
      },
      "action_plan": {
        "type": "array",
        "description": "具体行动计划"
      },
      "metrics": {
        "type": "object",
        "description": "预期效果指标"
      }
    }
  }
}
