{
  "version": "1.0",
  "test_cases": [
    {
      "id": "1",
      "scenario": "季度运营目标制定",
      "description": "运营总监需要为下季度制定运营目标，包括用户增长、转化率提升等",
      "difficulty": "medium",
      "input": {
        "business_context": "一家年营收5000万的电商公司，运营团队5人",
        "current_metrics": {
          "月活": 50000,
          "转化率": "3%",
          "客单价": 200
        },
        "target_improvement": "转化率提升至5%"
      },
      "expected_output": {
        "goal_clarity": "≥90%",
        "action_plan_complete": true,
        "key_actions": [
          "优化落地页",
          "调整营销策略",
          "用户分层运营"
        ],
        "timeline": "3个月"
      },
      "evaluation_points": [
        "目标是否清晰具体",
        "拆解是否完整可执行",
        "时间规划是否合理",
        "风险是否有预案"
      ]
    },
    {
      "id": "2",
      "scenario": "新业务拓展规划",
      "description": "公司准备开拓新区域市场，需要制定拓展规划",
      "difficulty": "high",
      "input": {
        "business_context": "在线教育公司准备进入二三线城市市场",
        "resource_constraints": {
          "budget": "100万",
          "team": "3人",
          "timeline": "6个月"
        }
      },
      "expected_output": {
        "market_analysis": "完整",
        "action_plan": "分阶段推进",
        "risk_response": "有预案"
      },
      "evaluation_points": [
        "市场分析是否深入",
        "阶段目标是否明确",
        "资源配置是否合理",
        "风险预案是否充分"
      ]
    }
  ],
  "evaluation_criteria": {
    "goal_clarity": "目标清晰、具体、可衡量",
    "plan_completeness": "行动计划完整、步骤清晰",
    "timeline_reasonableness": "时间安排合理、有缓冲",
    "resource_matching": "资源匹配度高",
    "risk_awareness": "风险识别全面、有预案"
  }
}
