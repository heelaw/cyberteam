{
  "skill_name": "同理心地图",
  "version": "v1.0",
  "eval_date": "2026-03-19",
  "test_cases": [
    {
      "case_id": "eval_001",
      "case_name": "便利店购物者同理心分析",
      "difficulty": "simple",
      "scenario": {
        "用户输入": "分析写字楼白领在便利店购物时的用户感受"
      },
      "expected_output": {
        "四象限": "完整四象限分析",
        "必须包含": [
          "看到/听到的具体内容",
          "想到/感受到的情绪",
          "说什么/做什么的描述",
          "至少2个痛点和期望",
          "言行差异分析"
        ]
      },
      "evaluation_criteria": [
        "四个象限是否完整",
        "洞察是否具体可落地",
        "是否基于合理假设"
      ]
    },
    {
      "case_id": "eval_002",
      "case_name": "在线医疗问诊用户同理心分析",
      "difficulty": "medium",
      "scenario": {
        "用户输入": "分析首次使用在线问诊服务的用户的心理和感受"
      },
      "expected_output": {
        "四象限": "完整四象限分析",
        "必须包含": [
          "用户所处环境和接收信息",
          "深层心理和情绪变化",
          "用户表达与实际行为差异",
          "核心痛点（至少3个）",
          "对平台的期望",
          "产品改进建议"
        ]
      },
      "evaluation_criteria": [
        "是否洞察到心理层面",
        "是否识别言行差异",
        "建议是否可落地"
      ]
    },
    {
      "case_id": "eval_003",
      "case_name": "B端企业管理员用户同理心分析",
      "difficulty": "hard",
      "scenario": {
        "用户输入": "分析B端SaaS产品中企业IT管理员的同理心，他们需要管理上百个员工账号"
      },
      "expected_output": {
        "四象限": "完整四象限分析",
        "必须包含": [
          "管理员的工作环境和压力",
          "多角色身份带来的冲突",
          "管理需求vs终端用户体验的平衡",
          "核心痛点（含老板和员工的双重压力）",
          "对产品的期望",
          "企业级产品改进建议"
        ]
      },
      "evaluation_criteria": [
        "是否理解B端管理员的双重身份",
        "洞察是否深入到心理层面",
        "建议是否可转化为产品需求"
      ]
    }
  ]
}
