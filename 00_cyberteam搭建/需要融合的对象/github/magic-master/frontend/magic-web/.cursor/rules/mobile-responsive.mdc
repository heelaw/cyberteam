# 移动端响应式设计规范

## 设计原则

1. **移动优先**: 从移动端开始设计，逐步增强到桌面端
2. **触摸友好**: 考虑触摸交互的特殊需求
3. **性能优先**: 移动端设备性能和网络限制
4. **内容优先**: 确保核心内容在小屏幕上可访问
5. **渐进增强**: 基础功能优先，高级功能作为增强

## 响应式断点标准

### 1. 断点定义

```typescript
// styles/breakpoints.ts
export const breakpoints = {
  xs: 0,      // 超小屏幕 (手机竖屏)
  sm: 576,    // 小屏幕 (手机横屏)
  md: 768,    // 中等屏幕 (平板竖屏)
  lg: 992,    // 大屏幕 (平板横屏/小桌面)
  xl: 1200,   // 超大屏幕 (桌面)
  xxl: 1600,  // 超超大屏幕 (大桌面)
} as const

export type Breakpoint = keyof typeof breakpoints

// 媒体查询工具
export const mediaQuery = {
  up: (bp: Breakpoint) => `@media (min-width: ${breakpoints[bp]}px)`,
  down: (bp: Breakpoint) => `@media (max-width: ${breakpoints[bp] - 1}px)`,
  between: (min: Breakpoint, max: Breakpoint) => 
    `@media (min-width: ${breakpoints[min]}px) and (max-width: ${breakpoints[max] - 1}px)`,
  only: (bp: Breakpoint) => {
    const keys = Object.keys(breakpoints) as Breakpoint[]
    const index = keys.indexOf(bp)
    const next = keys[index + 1]
    return next 
      ? `@media (min-width: ${breakpoints[bp]}px) and (max-width: ${breakpoints[next] - 1}px)`
      : `@media (min-width: ${breakpoints[bp]}px)`
  }
}
```

### 2. antd-style 响应式工具

```typescript
// hooks/useResponsive.ts
import { useResponsive as useAntdResponsive } from 'antd-style'

export const useResponsive = () => {
  const responsive = useAntdResponsive()
  
  return {
    ...responsive,
    // 自定义响应式状态
    isMobile: responsive.xs || responsive.sm,
    isTablet: responsive.md || responsive.lg,
    isDesktop: responsive.xl || responsive.xxl,
    
    // 屏幕尺寸判断
    isSmallScreen: responsive.xs,
    isMediumScreen: responsive.md,
    isLargeScreen: responsive.xl,
  }
}

// 使用示例
const ResponsiveComponent = () => {
  const { isMobile, isTablet, isDesktop } = useResponsive()
  
  return (
    <div>
      {isMobile && <MobileLayout />}
      {isTablet && <TabletLayout />}
      {isDesktop && <DesktopLayout />}
    </div>
  )
}
```

## 移动端交互规范

### 1. 触摸目标尺寸

```typescript
// styles/touch-targets.ts
export const touchTargets = {
  // 最小触摸目标尺寸 (44px x 44px)
  minSize: 44,
  
  // 推荐触摸目标尺寸
  recommended: {
    button: 48,
    icon: 44,
    listItem: 56,
    fab: 56,
  },
  
  // 触摸目标间距
  spacing: {
    minimum: 8,   // 最小间距
    comfortable: 16, // 舒适间距
  }
} as const

// 触摸友好的样式 mixin
export const createTouchFriendlyStyles = () => ({
  minHeight: touchTargets.minSize,
  minWidth: touchTargets.minSize,
  padding: '12px 16px',
  margin: touchTargets.spacing.minimum,
  cursor: 'pointer',
  userSelect: 'none',
  WebkitTapHighlightColor: 'transparent',
  
  // 触摸反馈
  '&:active': {
    transform: 'scale(0.98)',
    transition: 'transform 0.1s ease',
  },
})
```

### 2. 手势支持

```typescript
// hooks/useGestures.ts
import { useSpring, useGesture } from '@use-gesture/react'

interface UseSwipeOptions {
  onSwipeLeft?: () => void
  onSwipeRight?: () => void
  onSwipeUp?: () => void
  onSwipeDown?: () => void
  threshold?: number
}

export const useSwipe = (options: UseSwipeOptions) => {
  const {
    onSwipeLeft,
    onSwipeRight,
    onSwipeUp,
    onSwipeDown,
    threshold = 50,
  } = options

  const bind = useGesture({
    onDrag: ({ movement: [mx, my], last, cancel }) => {
      if (last) {
        const absX = Math.abs(mx)
        const absY = Math.abs(my)
        
        if (Math.max(absX, absY) > threshold) {
          if (absX > absY) {
            // 水平滑动
            if (mx > 0) {
              onSwipeRight?.()
            } else {
              onSwipeLeft?.()
            }
          } else {
            // 垂直滑动
            if (my > 0) {
              onSwipeDown?.()
            } else {
              onSwipeUp?.()
            }
          }
        }
      }
    },
  })

  return bind
}

// 长按手势
export const useLongPress = (callback: () => void, delay = 500) => {
  const bind = useGesture({
    onPointerDown: ({ event }) => {
      const timer = setTimeout(() => {
        callback()
      }, delay)
      
      const cleanup = () => {
        clearTimeout(timer)
        document.removeEventListener('pointerup', cleanup)
        document.removeEventListener('pointercancel', cleanup)
      }
      
      document.addEventListener('pointerup', cleanup)
      document.addEventListener('pointercancel', cleanup)
    },
  })

  return bind
}
```

### 3. 虚拟键盘适配

```typescript
// hooks/useVirtualKeyboard.ts
import { useState, useEffect } from 'react'

export const useVirtualKeyboard = () => {
  const [isVisible, setIsVisible] = useState(false)
  const [height, setHeight] = useState(0)

  useEffect(() => {
    // 检测虚拟键盘
    const detectKeyboard = () => {
      if ('visualViewport' in window) {
        const handleViewportChange = () => {
          const viewport = window.visualViewport!
          const keyboardHeight = window.innerHeight - viewport.height
          
          setIsVisible(keyboardHeight > 150) // 阈值150px
          setHeight(keyboardHeight)
        }

        window.visualViewport!.addEventListener('resize', handleViewportChange)
        return () => {
          window.visualViewport!.removeEventListener('resize', handleViewportChange)
        }
      } else {
        // 降级方案：监听窗口尺寸变化
        let initialHeight = window.innerHeight
        
        const handleResize = () => {
          const currentHeight = window.innerHeight
          const heightDiff = initialHeight - currentHeight
          
          setIsVisible(heightDiff > 150)
          setHeight(heightDiff)
        }

        window.addEventListener('resize', handleResize)
        return () => {
          window.removeEventListener('resize', handleResize)
        }
      }
    }

    return detectKeyboard()
  }, [])

  return { isVisible, height }
}

// 自动调整布局的组件
const KeyboardAdaptiveLayout = ({ children }: { children: React.ReactNode }) => {
  const { isVisible, height } = useVirtualKeyboard()
  
  return (
    <div
      style={{
        paddingBottom: isVisible ? height : 0,
        transition: 'padding-bottom 0.3s ease',
      }}
    >
      {children}
    </div>
  )
}
```

