## 测试和调试

### 1. 移动端测试工具

```typescript
// utils/mobile-debug.ts
class MobileDebugger {
  private static logContainer: HTMLElement | null = null

  // 移动端控制台
  static createMobileConsole() {
    if (this.logContainer) return

    this.logContainer = document.createElement('div')
    this.logContainer.style.cssText = `
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      height: 200px;
      background: rgba(0, 0, 0, 0.9);
      color: white;
      font-size: 12px;
      padding: 10px;
      overflow-y: auto;
      z-index: 9999;
      font-family: monospace;
      display: none;
    `
    
    document.body.appendChild(this.logContainer)

    // 三指点击显示/隐藏
    let touchCount = 0
    document.addEventListener('touchstart', (e) => {
      if (e.touches.length === 3) {
        touchCount++
        if (touchCount === 2) {
          this.toggle()
          touchCount = 0
        }
        setTimeout(() => { touchCount = 0 }, 1000)
      }
    })

    // 重写 console 方法
    const originalLog = console.log
    const originalError = console.error
    const originalWarn = console.warn

    console.log = (...args) => {
      originalLog.apply(console, args)
      this.addLog('LOG', args.join(' '))
    }

    console.error = (...args) => {
      originalError.apply(console, args)
      this.addLog('ERROR', args.join(' '), '#ff4444')
    }

    console.warn = (...args) => {
      originalWarn.apply(console, args)
      this.addLog('WARN', args.join(' '), '#ffaa00')
    }
  }

  private static addLog(type: string, message: string, color = '#ffffff') {
    if (!this.logContainer) return

    const logEntry = document.createElement('div')
    logEntry.style.cssText = `
      margin-bottom: 5px;
      padding: 2px 0;
      border-bottom: 1px solid #333;
      color: ${color};
    `
    logEntry.innerHTML = `<strong>[${type}]</strong> ${message}`
    
    this.logContainer.appendChild(logEntry)
    this.logContainer.scrollTop = this.logContainer.scrollHeight
  }

  private static toggle() {
    if (!this.logContainer) return
    
    const isVisible = this.logContainer.style.display !== 'none'
    this.logContainer.style.display = isVisible ? 'none' : 'block'
  }

  // 设备信息收集
  static getDeviceInfo() {
    return {
      userAgent: navigator.userAgent,
      screenSize: `${screen.width}x${screen.height}`,
      viewportSize: `${window.innerWidth}x${window.innerHeight}`,
      devicePixelRatio: window.devicePixelRatio,
      touchSupport: 'ontouchstart' in window,
      orientation: screen.orientation?.type || 'unknown',
      connection: (navigator as any).connection?.effectiveType || 'unknown',
    }
  }
}

// 开发环境自动启用
if (process.env.NODE_ENV === 'development') {
  MobileDebugger.createMobileConsole()
}
```

