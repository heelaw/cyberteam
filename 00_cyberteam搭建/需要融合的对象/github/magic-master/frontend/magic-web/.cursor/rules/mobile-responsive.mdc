// components/MobileTable.tsx
import { Card, Collapse, Space, Tag } from 'antd'
import { createStyles } from 'antd-style'
import { useResponsive } from '@/hooks/useResponsive'

const useStyles = createStyles(({ token, css }) => ({
  mobileTable: css`
    .ant-card {
      margin-bottom: 8px;
    }
  `,
  
  cardHeader: css`
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 500;
  `,
  
  cardContent: css`
    margin-top: 12px;
  `,
  
  fieldRow: css`
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
    
    &:last-child {
      margin-bottom: 0;
    }
  `,
  
  fieldLabel: css`
    color: ${token.colorTextSecondary};
    font-size: 14px;
  `,
  
  fieldValue: css`
    font-weight: 500;
  `,
}))

interface MobileTableProps<T> {
  data: T[]
  renderCard: (item: T, index: number) => {
    title: React.ReactNode
    content: Array<{
      label: string
      value: React.ReactNode
    }>
    actions?: React.ReactNode
  }
}

function MobileTable<T>({ data, renderCard }: MobileTableProps<T>) {
  const { styles } = useStyles()
  const { isMobile } = useResponsive()

  if (!isMobile) {
    return null // 非移动端不渲染
  }

  return (
    <div className={styles.mobileTable}>
      {data.map((item, index) => {
        const { title, content, actions } = renderCard(item, index)
        
        return (
          <Card key={index} size="small">
            <div className={styles.cardHeader}>
              <span>{title}</span>
              {actions && <Space>{actions}</Space>}
            </div>
            
            <div className={styles.cardContent}>
              {content.map((field, fieldIndex) => (
                <div key={fieldIndex} className={styles.fieldRow}>
                  <span className={styles.fieldLabel}>{field.label}:</span>
                  <span className={styles.fieldValue}>{field.value}</span>
                </div>
              ))}
            </div>
          </Card>
        )
      })}
    </div>
  )
}
