## 数据验证

### 1. 输入验证

```typescript
// utils/validators.ts
class Validators {
	// 邮箱验证
	static isValidEmail(email: string): boolean {
		const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/
		return emailRegex.test(email) && email.length <= 254
	}

	// 密码强度验证
	static isStrongPassword(password: string): {
		isValid: boolean
		errors: string[]
	} {
		const errors: string[] = []

		if (password.length < 8) {
			errors.push("密码长度至少8位")
		}

		if (!/[A-Z]/.test(password)) {
			errors.push("密码必须包含大写字母")
		}

		if (!/[a-z]/.test(password)) {
			errors.push("密码必须包含小写字母")
		}

		if (!/\d/.test(password)) {
			errors.push("密码必须包含数字")
		}

		if (!/[!@#$%^&*(),.?":{}|<>]/.test(password)) {
			errors.push("密码必须包含特殊字符")
		}

		return {
			isValid: errors.length === 0,
			errors,
		}
	}

	// 防止 SQL 注入的字符串验证
	static isSafeString(input: string): boolean {
		const dangerousPatterns = [
			/(\b(SELECT|INSERT|UPDATE|DELETE|DROP|CREATE|ALTER|EXEC|UNION)\b)/i,
			/(\b(OR|AND)\s+\d+\s*=\s*\d+)/i,
			/(--|\*\/|\/\*)/,
			/['"`;]/,
		]

		return !dangerousPatterns.some((pattern) => pattern.test(input))
	}

	// 文件类型验证
	static isAllowedFileType(file: File, allowedTypes: string[]): boolean {
		return allowedTypes.includes(file.type)
	}

	// 文件大小验证
	static isValidFileSize(file: File, maxSizeInMB: number): boolean {
		const maxSizeInBytes = maxSizeInMB * 1024 * 1024
		return file.size <= maxSizeInBytes
	}
}
```

## 安全监控

### 1. 安全事件记录

```typescript
// utils/security-monitor.ts
interface SecurityEvent {
	type: string
	severity: "low" | "medium" | "high" | "critical"
	message: string
	userAgent?: string
	ip?: string
	timestamp: number
	userId?: string
}

class SecurityMonitor {
	private static events: SecurityEvent[] = []

	// 记录安全事件
	static logEvent(event: Omit<SecurityEvent, "timestamp">): void {
		const securityEvent: SecurityEvent = {
			...event,
			timestamp: Date.now(),
		}

		this.events.push(securityEvent)

		// 发送到服务器
		this.sendToServer(securityEvent)

		// 严重事件立即报警
		if (event.severity === "critical") {
			this.triggerAlert(securityEvent)
		}
	}

	// 记录登录失败
	static logFailedLogin(username: string): void {
		this.logEvent({
			type: "failed_login",
			severity: "medium",
			message: `Failed login attempt for user: ${username}`,
			userAgent: navigator.userAgent,
		})
	}

	// 记录可疑活动
	static logSuspiciousActivity(activity: string, details?: string): void {
		this.logEvent({
			type: "suspicious_activity",
			severity: "high",
			message: `Suspicious activity detected: ${activity}`,
			userAgent: navigator.userAgent,
		})
	}

	// 发送到服务器
	private static async sendToServer(event: SecurityEvent): Promise<void> {
		try {
			await fetch("/api/security/events", {
				method: "POST",
				headers: {
					"Content-Type": "application/json",
				},
				body: JSON.stringify(event),
			})
		} catch (error) {
			console.error("Failed to send security event:", error)
		}
	}

	// 触发报警
	private static triggerAlert(event: SecurityEvent): void {
		// 实现报警逻辑（邮件、短信、推送等）
		console.error("SECURITY ALERT:", event)
	}
}
```

