{
  "version": "1.1",
  "core_theory": {
    "name": "增长业务模型规划",
    "source": "业务操盘手课程 - 第一章：全局业务模型",
    "summary": "在全局业务模型基础上，规划可规模化的增长路径，回答'如何实现N倍增长'的问题",
    "key_principle": "找到业务模型中可被规模化复制的增长杠杆，放大收入公式中某个或某几个关键变量"
  },
  "fundamental_question": "如何实现N倍增长？",
  "growth_formula": {
    "base": "收入 = 流量 × 转化率 × 客单价",
    "expanded": "收入 = 流量 × 转化率 × 客单价 × 复购次数",
    "variables": [
      {
        "name": "流量",
        "description": "获取用户的能力",
        "metrics": ["DAU", "MAU", "新增用户数", "CAC"]
      },
      {
        "name": "转化率",
        "description": "将流量转化为收入的能力",
        "metrics": ["注册转化率", "付费转化率", "完成率"]
      },
      {
        "name": "客单价",
        "description": "单次交易或用户贡献的收入",
        "metrics": ["ARPU", "客单价", "LTV"]
      },
      {
        "name": "复购次数",
        "description": "用户持续贡献收入的次数",
        "metrics": ["复购率", "续费率", "NPS"]
      }
    ]
  },
  "growth_paths": [
    {
      "path": "流量增长",
      "methods": [
        {
          "name": "渠道扩展",
          "description": "开拓新获客渠道",
          "examples": ["SEO", "信息流投放", "社交媒体", "线下渠道"]
        },
        {
          "name": "渠道深耕",
          "description": "提升现有渠道效率",
          "examples": ["优化投放素材", "提升内容质量", "活动运营"]
        },
        {
          "name": "增长黑客",
          "description": "低成本获客方式",
          "examples": ["裂变活动", "病毒传播", "口碑营销"]
        },
        {
          "name": "内容营销",
          "description": "持续输出获取自然流量",
          "examples": ["公众号", "短视频", "直播"]
        }
      ],
      "key_metrics": ["CAC", "流量来源占比", "渠道ROI"]
    },
    {
      "path": "转化提升",
      "methods": [
        {
          "name": "产品优化",
          "description": "提升产品吸引力",
          "examples": ["优化CTA", "改进页面", "功能迭代"]
        },
        {
          "name": "流程优化",
          "description": "降低转化阻力",
          "examples": ["简化注册流程", "优化支付流程", "减少跳失"]
        },
        {
          "name": "体验优化",
          "description": "提升用户意愿",
          "examples": ["客服优化", "售后保障", "社群运营"]
        },
        {
          "name": "定价策略",
          "description": "优化价格策略",
          "examples": ["促销活动", "定价测试", "套餐设计"]
        }
      ],
      "key_metrics": ["转化率", "跳出率", "完成率"]
    },
    {
      "path": "客单价提升",
      "methods": [
        {
          "name": "产品升级",
          "description": "推出高价值版本",
          "examples": ["推出Pro版", "增值服务", "高端产品线"]
        },
        {
          "name": "组合销售",
          "description": "捆绑销售策略",
          "examples": ["套餐", "满减", "买赠"]
        },
        {
          "name": "LTV挖掘",
          "description": "提升用户生命周期价值",
          "examples": ["会员体系", "积分体系", "个性化推荐"]
        },
        {
          "name": "交叉销售",
          "description": "推荐相关产品",
          "examples": ["相关推荐", "互补品推荐"]
        }
      ],
      "key_metrics": ["ARPU", "客单价", "LTV"]
    }
  ],
  "growth_model_assessment": [
    {
      "dimension": "天花板",
      "question": "市场规模是否足够大？",
      "analysis": ["TAM分析（总可市场）", "SAM分析（可服务市场）", "SOM分析（可获得市场）"]
    },
    {
      "dimension": "可持续性",
      "question": "增长能否持续？",
      "analysis": ["复购率", "续费率", "自然增长率", "流失率"]
    },
    {
      "dimension": "盈利能力",
      "question": "增长是否盈利？",
      "analysis": ["LTV/CAC > 3", "回收周期", "Unit Economics"]
    },
    {
      "dimension": "竞争壁垒",
      "question": "增长能否形成壁垒？",
      "analysis": ["网络效应", "品牌壁垒", "数据壁垒", "规模壁垒"]
    },
    {
      "dimension": "风险",
      "question": "增长有哪些风险？",
      "analysis": ["市场风险", "竞争风险", "政策风险", "执行风险"]
    }
  ],
  "unit_economics": {
    "LTV": {
      "name": "用户生命周期价值",
      "formula": "LTV = ARPU × 用户生命周期（月）",
      "example": "月ARPU 500元 × 24个月 = 12000元"
    },
    "CAC": {
      "name": "用户获取成本",
      "formula": "CAC = 营销费用 ÷ 新增用户数",
      "example": "10万 ÷ 1000人 = 100元/人"
    },
    "LTV_CAC_ratio": {
      "name": "生命周期价值比",
      "standard": "应大于3",
      "good": "大于5为优秀",
      "warning": "小于3需要优化获客成本"
    },
    "payback_period": {
      "name": "回收周期",
      "standard": "越短越好",
      "good": "小于12个月",
      "warning": "超过18个月风险较高"
    }
  },
  "case_studies": [
    {
      "name": "滴滴增长案例",
      "growth_model": "网络效应+规模经济",
      "key_insight": "双边市场，供给驱动需求，形成正向循环",
      "growth_ levers": ["司机端拓展", "乘客端补贴", "地域扩张"],
      "unit_economics": "LTV/CAC > 5"
    },
    {
      "name": "美团增长案例",
      "growth_model": "本地生活服务+品类扩展",
      "key_insight": "从到店到酒旅，品类延伸带来增长",
      "growth_ levers": ["品类扩展", "地域覆盖", "供给端建设"],
      "unit_economics": "不同品类差异大"
    },
    {
      "name": "拼多多增长案例",
      "growth_model": "社交裂变+低价策略",
      "key_insight": "微信社交链传播，低价获取下沉市场",
      "growth_ levers": ["拼团机制", "低价策略", "社交传播"],
      "unit_economics": "CAC极低，自然增长占比高"
    }
  ],
  "references": [
    {
      "name": "增长黑客",
      "author": "肖恩·埃利斯",
      "core_concept": "AARRR模型，低成本增长策略"
    },
    {
      "name": "精益增长",
      "author": "布拉德·费尔德",
      "core_concept": "快速验证增长假设"
    },
    {
      "name": "平台战略",
      "author": "陈威如",
      "core_concept": "网络效应增长模型"
    },
    {
      "name": "从0到1",
      "author": "蒂尔",
      "core_concept": "创新增长模式"
    }
  ]
}
