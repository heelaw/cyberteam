{
  "skill_name": "社群价值提供三法",
  "version": "1.0",
  "eval_type": "skill_functional",
  "test_cases": [
    {
      "id": 1,
      "difficulty": "simple",
      "category": "免费健身社群",
      "input": {
        "scenario": "你计划创建一个免费的北京健身爱好者社群，成员300人，需要设计社群提供的核心价值"
      },
      "expected_output": {
        "must_include": [
          "三法组合方案",
          "打卡监督机制",
          "激励体系",
          "执行排期"
        ],
        "output_structure": "免费社群价值方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "feasibility": "是否可执行",
        "value": "是否体现免费社群价值",
        "sustainability": "是否能持续发展"
      }
    },
    {
      "id": 2,
      "difficulty": "medium",
      "category": "付费学习社群",
      "input": {
        "scenario": "你计划创建一个299元/年的产品经理付费社群，目标用户是0-3岁产品经理，需要设计社群提供的核心价值"
      },
      "expected_output": {
        "must_include": [
          "价值定位",
          "三法组合方案",
          "排期计划",
          "资源清单",
          "复盘机制"
        ],
        "output_structure": "完整价值提供方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "是否完整",
        "value": "是否体现付费价值感",
        "feasibility": "是否可执行"
      }
    },
    {
      "id": 3,
      "difficulty": "hard",
      "category": "综合型高端社群",
      "input": {
        "scenario": "你计划创建一个年费9999元的企业家社群，需要提供综合价值，包括人脉对接、商业咨询、资源整合等"
      },
      "expected_output": {
        "must_include": [
          "高端价值定位",
          "三法定制组合",
          "差异化服务设计",
          "资源整合方案",
          "高端权益体系",
          "持续价值输出计划"
        ],
        "output_structure": "高端社群完整价值方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "professionalism": "是否体现高端专业感",
        "completeness": "体系是否完整",
        "differentiation": "是否有差异化"
      }
    }
  ],
  "evaluation_methodology": {
    "scoring": "每个维度1-5分，5分制评分",
    "pass_criteria": "总分≥15分（满分25分），且每个维度≥3分",
    "process": "1.确定社群定位 2.设计三法组合 3.制定执行计划 4.准备资源 5.设计复盘机制"
  },
  "coverage": {
    "场景覆盖": ["免费社群", "付费社群", "高端社群"],
    "难度分布": {
      "simple": 1,
      "medium": 1,
      "hard": 1
    }
  }
}
