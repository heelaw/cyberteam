{
  "skill_name": "社群变现模式法",
  "version": "1.0",
  "eval_type": "skill_functional",
  "test_cases": [
    {
      "id": 1,
      "difficulty": "simple",
      "category": "免费社群首次变现",
      "input": {
        "scenario": "你运营一个300人的产品经理学习社群，提供学习资料和答疑服务，目前免费运营，希望设计变现模式"
      },
      "expected_output": {
        "must_include": [
          "价值评估",
          "变现模式选择",
          "产品设计",
          "价格体系",
          "转化路径"
        ],
        "output_structure": "基础变现方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "feasibility": "是否可执行",
        "suitability": "模式是否适合",
        "completeness": "方案是否完整"
      }
    },
    {
      "id": 2,
      "difficulty": "medium",
      "category": "付费社群变现优化",
      "input": {
        "scenario": "你运营一个500人的知识付费社群，年费299元，现有会员200人，月收入6万，希望提升到月收入10万"
      },
      "expected_output": {
        "must_include": [
          "现有变现分析",
          "产品矩阵设计",
          "价格优化方案",
          "转化提升方案",
          "执行计划"
        ],
        "output_structure": "变现优化方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "professionalism": "方案是否专业",
        "feasibility": "是否可执行",
        "effectiveness": "是否能有效提升"
      }
    },
    {
      "id": 3,
      "difficulty": "hard",
      "category": "品牌私域电商变现",
      "input": {
        "scenario": "你有一个美妆品牌的私域社群，3000人，都是老客户，复购率40%，希望设计电商带货为主的变现模式"
      },
      "expected_output": {
        "must_include": [
          "变现模式组合",
          "产品选品策略",
          "带货话术模板",
          "活动设计方案",
          "转化数据目标",
          "风险控制"
        ],
        "output_structure": "完整电商变现方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "方案是否完整",
        "professionalism": "是否体现电商专业",
        "feasibility": "是否可执行",
        "risk_control": "风险控制是否完善"
      }
    }
  ],
  "evaluation_methodology": {
    "scoring": "每个维度1-5分，5分制评分",
    "pass_criteria": "总分≥15分（满分25分），且每个维度≥3分",
    "process": "1.价值评估 2.模式选择 3.产品设计 4.路径设计 5.执行迭代"
  },
  "coverage": {
    "场景覆盖": ["首次变现", "变现优化", "电商变现"],
    "难度分布": {
      "simple": 1,
      "medium": 1,
      "hard": 1
    }
  }
}
