{
  "skill_name": "5W1H分析法",
  "version": "v1.0",
  "eval_date": "2026-03-19",
  "test_cases": [
    {
      "case_id": "eval_001",
      "case_name": "门店用户流失分析",
      "difficulty": "simple",
      "scenario": {
        "用户输入": "门店进店顾客很多但成交率低，怎么分析？"
      },
      "expected_output": {
        "要素覆盖": [
          "What: 成交率低的具体数据",
          "Why: 需要分析原因",
          "Who: 进店顾客特征",
          "When: 需要明确时间范围",
          "Where: 门店场景",
          "How: 需还原用户行为路径"
        ],
        "必须包含": [
          "六个要素的完整分析",
          "问题量化的具体数据",
          "初步原因假设"
        ]
      },
      "evaluation_criteria": [
        "六个要素是否全部覆盖",
        "是否有具体数据支撑",
        "是否有初步建议"
      ]
    },
    {
      "case_id": "eval_002",
      "case_name": "App用户活跃度下降",
      "difficulty": "medium",
      "scenario": {
        "用户输入": "App日活从100万降到70万，产品经理让你分析原因"
      },
      "expected_output": {
        "要素覆盖": [
          "What: DAU下降30%，从100万到70万",
          "Why: 多因素导致，需深入分析",
          "Who: 需进行用户分层（新用户/老用户/活跃度分层）",
          "When: 需明确时间点和持续周期",
          "Where: App端，区分各渠道",
          "How: 需还原用户流失路径和关键节点"
        ],
        "必须包含": [
          "流失用户的分层分析",
          "问题发生的时间特征",
          "关键流失节点定位",
          "根因假设及置信度"
        ]
      },
      "evaluation_criteria": [
        "六个要素是否完整",
        "是否有用户分层分析",
        "根因假设是否有数据支撑"
      ]
    },
    {
      "case_id": "eval_003",
      "case_name": "B端企业用户续费率下降",
      "difficulty": "hard",
      "scenario": {
        "用户输入": "B端企业客户年续费率从85%降到65%，需要全面分析并输出改善方案"
      },
      "expected_output": {
        "要素覆盖": [
          "What: 续费率从85%降至65%，降幅20个百分点",
          "Why: 需要深入分析多重因素（B端特殊性）",
          "Who: 需区分企业规模/行业/决策人角色",
          "When: 需要明确时间周期和变化趋势",
          "Where: B端产品使用场景",
          "How: 需要还原企业采购决策全流程"
        ],
        "必须包含": [
          "B端和C端用户的区分",
          "企业规模/行业分层分析",
          "续费决策链分析（采购人/使用人/决策人）",
          "竞对替换成本评估",
          "完整的根因验证方案",
          "分阶段的改善计划（短期/中期/长期）"
        ]
      },
      "evaluation_criteria": [
        "是否体现B端业务的特殊性",
        "是否覆盖企业决策全流程",
        "改善方案是否分阶段可执行"
      ]
    }
  ]
}
