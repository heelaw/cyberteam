{
  "skill_name": "价值努力矩阵",
  "version": "v1.0",
  "eval_date": "2026-03-19",
  "test_cases": [
    {
      "case_id": "eval_001",
      "case_name": "运营活动优先级排序",
      "difficulty": "simple",
      "scenario": {
        "用户输入": "下个月有5个运营活动想做，时间只够做2个，怎么排"
      },
      "expected_output": {
        "选项列表": "5个活动的完整列表",
        "必须包含": [
          "每个活动的价值评估",
          "每个活动的努力评估",
          "价值努力矩阵图",
          "最终选择的2个活动及理由"
        ]
      },
      "evaluation_criteria": [
        "评估是否合理",
        "是否选择了最优解",
        "理由是否充分"
      ]
    },
    {
      "case_id": "eval_002",
      "case_name": "技术债务vs新功能优先级",
      "difficulty": "medium",
      "scenario": {
        "用户输入": "团队有5个技术债务要还，也有5个新功能要做，怎么平衡"
      },
      "expected_output": {
        "双视角": "技术债务 + 新功能",
        "必须包含": [
          "技术债务的价值评估（为什么必须做）",
          "新功能的价值评估",
          "两类选项的统一矩阵",
          "平衡策略建议",
          "分阶段规划"
        ]
      },
      "evaluation_criteria": [
        "技术债务是否被公平对待",
        "矩阵是否统一评估",
        "是否有平衡策略"
      ]
    },
    {
      "case_id": "eval_003",
      "case_name": "年度产品规划优先级",
      "difficulty": "hard",
      "scenario": {
        "用户输入": "创业公司全年有20+需求想实现，团队5人，怎么做全年规划"
      },
      "expected_output": {
        "完整规划": "20+需求的全面分析",
        "必须包含": [
          "所有需求的分类整理",
          "每个需求的完整价值-努力评估",
          "年度四象限分布图",
          "分季度路线图（Q1-Q4）",
          "资源约束下的决策逻辑",
          "风险评估和备选方案",
          "动态调整机制"
        ]
      },
      "evaluation_criteria": [
        "是否有全年视角",
        "计划是否可落地执行",
        "是否有动态调整机制"
      ]
    }
  ]
}
