{
  "skill_name": "流程化思维法",
  "version": "v1.0",
  "eval_date": "2026-03-19",
  "test_cases": [
    {
      "case_id": "eval_001",
      "case_name": "简单的用户注册流程",
      "difficulty": "simple",
      "scenario": {
        "用户输入": "帮我画一个用户注册APP的流程，目标是将注册转化率从10%提升到20%"
      },
      "expected_output": {
        "目标": "注册转化率10%→20%",
        "流程步骤": "5-7步完成",
        "符号使用": "正确使用五符号",
        "关键因素": "标注了影响转化的关键步骤"
      },
      "evaluation_criteria": [
        "目标是否量化清晰",
        "流程步骤是否完整",
        "五符号使用是否正确"
      ]
    },
    {
      "case_id": "eval_002",
      "case_name": "目标不清晰需要澄清",
      "difficulty": "medium",
      "scenario": {
        "用户输入": "我想优化我们的业务流程，但不知道具体要优化什么"
      },
      "expected_output": {
        "处理方式": "引导明确目标",
        "澄清问题": "了解当前痛点",
        "目标模板": "提供目标定义模板"
      },
      "evaluation_criteria": [
        "是否先澄清目标",
        "是否使用目标模板引导",
        "是否能发现用户痛点"
      ]
    },
    {
      "case_id": "eval_003",
      "case_name": "多部门利益糾葛的流程优化",
      "difficulty": "hard",
      "scenario": {
        "用户输入": "我想优化退货流程，但客服说退货太多影响考核，仓库说退货太多工作量太大，财务说退货退款太麻烦，各部门都有道理，我该怎么办？"
      },
      "expected_output": {
        "处理方式": "建立共同目标",
        "流程图": "清晰标注各方责任和接口",
        "利益分析": "识别各方的核心诉求",
        "优化方案": "在满足各方合理诉求的前提下优化流程"
      },
      "evaluation_criteria": [
        "是否能建立共同目标",
        "流程图是否能协调各方利益",
        "是否提供多方共赢的优化建议"
      ]
    }
  ]
}
