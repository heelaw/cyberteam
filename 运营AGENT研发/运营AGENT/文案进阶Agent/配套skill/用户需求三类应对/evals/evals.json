{
  "skill_name": "用户需求三类应对",
  "version": "1.0",
  "evals": [
    {
      "id": "eval_1",
      "difficulty": "simple",
      "scenario": "在线课程",
      "input": {
        "产品名称": "Python课程",
        "用户不买的原因": "不知道能不能学会，学完能不能找到工作"
      },
      "expected_output": {
        "需求诊断": {
          "需求类型": "功能型",
          "核心痛点": "担心效果不确定",
          "优先级": "主要"
        },
        "策略建议": {
          "匹配策略": ["效果量化", "证据证明"],
          "证据准备": ["学员案例", "就业数据"],
          "文案方向": "21天学会Python，做项目找工作"
        },
        "文案产出": {
          "主文案": "21天学会Python，独立完成项目，转行做程序员",
          "辅助": "10万学员验证，平均涨薪50%"
        }
      },
      "validation_points": [
        "判断为功能型需求",
        "策略匹配效果量化"
      ]
    },
    {
      "id": "eval_2",
      "difficulty": "medium",
      "scenario": "消费品",
      "input": {
        "产品名称": "轻奢女包",
        "用户不买的原因": "感觉背出去有没有面子"
      },
      "expected_output": {
        "需求诊断": {
          "需求类型": "情感型",
          "核心痛点": "担心身份不匹配",
          "优先级": "主要"
        },
        "策略建议": {
          "匹配策略": ["身份认同", "场景共鸣"],
          "证据准备": ["目标用户画像", "使用场景"],
          "文案方向": "精致女人的选择"
        },
        "文案产出": {
          "主文案": "每个精致女人，都值得拥有",
          "辅助": "背出自信，活出态度"
        }
      },
      "validation_points": [
        "判断为情感型需求",
        "策略匹配身份认同"
      ]
    },
    {
      "id": "eval_3",
      "difficulty": "hard",
      "scenario": "企业服务",
      "input": {
        "产品名称": "CRM系统",
        "用户不买的原因": "担心不稳定怕数据丢失，而且同行都没用我们自己开发行不行"
      },
      "expected_output": {
        "需求诊断": {
          "需求类型": "混合型（功能+社会）",
          "核心痛点": "功能担心+社会认同",
          "优先级": "主要-功能，次要-社会"
        },
        "策略建议": {
          "匹配策略": ["证据证明", "权威背书"],
          "证据准备": ["稳定性数据", "行业案例", "安全认证"],
          "文案方向": "XX大企业都在用"
        },
        "文案产出": {
          "功能文案": "99.99%可用性，数据零丢失",
          "社会文案": "500+企业都在用，包括XX上市公司"
        },
        "验证建议": {
          "测试方法": "A/B测试不同文案版本",
          "评估指标": "点击率、转化率、留资率"
        }
      },
      "validation_points": [
        "识别混合型需求",
        "区分主要和次要需求",
        "功能文案和社会文案分离"
      ]
    }
  ]
}
