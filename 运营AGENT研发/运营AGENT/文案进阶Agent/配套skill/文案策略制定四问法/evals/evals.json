{
  "skill_name": "文案策略制定四问法",
  "version": "1.0",
  "evals": [
    {
      "id": "eval_1",
      "difficulty": "simple",
      "scenario": "在线课程推广",
      "input": {
        "产品名称": "Python入门课程",
        "目标用户": "想转行做程序员的零基础小白",
        "文案目的": "招生",
        "竞品": "其他Python课程"
      },
      "expected_output": {
        "问题一": {
          "目标用户": "想转行的零基础小白",
          "用户特征": ["非计算机专业", "可能有一定工作经验", "想快速转行"],
          "用户痛点": ["不知道能不能学会", "怕学不会浪费钱", "不知道学完能不能找到工作"],
          "用户关心": ["能不能学会", "能不能找到工作", "学完能做什么"]
        },
        "问题二": {
          "文案目标": "欲望/行动",
          "理由": "用户已经知道想学Python，主要是如何选择的问题"
        },
        "问题三": {
          "核心卖点": "21天学会Python，能做项目",
          "差异化": "时间明确，效果可量化"
        },
        "问题四": {
          "用户状态": "考虑中",
          "匹配风格": "信任型、证据型",
          "文案方向": "展示学习效果和学员案例"
        }
      },
      "validation_points": [
        "用户画像具体",
        "目标唯一",
        "卖点有差异化"
      ]
    },
    {
      "id": "eval_2",
      "difficulty": "medium",
      "scenario": "电商店铺推广",
      "input": {
        "产品名称": "无糖气泡水",
        "目标用户": "年轻白领、健身人群",
        "文案目的": "卖货"
      },
      "expected_output": {
        "问题一": {
          "目标用户": "年轻白领、健身人群",
          "用户特征": ["25-35岁", "注重健康", "有一定消费能力"],
          "用户痛点": ["想喝甜的又怕胖", "普通饮料糖分太高"],
          "用户关心": ["口味", "健康", "价格"]
        },
        "问题二": {
          "文案目标": "欲望/行动",
          "理由": "产品认知已有，需要激发购买"
        },
        "问题三": {
          "核心卖点": "0糖0卡好喝",
          "差异化": "解决了想喝甜又怕胖的矛盾"
        },
        "问题四": {
          "用户状态": "知道/考虑中",
          "匹配风格": "场景型、促销型",
          "文案方向": "场景带入+限时优惠"
        }
      },
      "validation_points": [
        "用户画像清晰",
        "目标明确"
      ]
    },
    {
      "id": "eval_3",
      "difficulty": "hard",
      "scenario": "企业服务推广",
      "input": {
        "产品名称": "企业协同办公平台",
        "目标用户": "中小企业老板/IT负责人",
        "文案目的": "获取销售线索",
        "竞品": "钉钉、飞书",
        "投放渠道": "百度搜索+行业垂直媒体"
      },
      "expected_output": {
        "问题一": {
          "目标用户": "中小企业老板、IT负责人",
          "用户特征": ["30-45岁", "管理50-500人团队", "关注效率和成本"],
          "用户痛点": ["工具太多切换麻烦", "数据不通", "审批流程乱", "担心数据安全"],
          "用户关心": ["能否提升效率", "是否易用", "价格", "数据安全"]
        },
        "问题二": {
          "文案目标": "认知/兴趣",
          "理由": "企业采购决策复杂，需要多轮沟通，先建立认知"
        },
        "问题三": {
          "核心卖点": "一体化解决方案+国产化适配",
          "差异化": "一个平台解决所有协作问题+支持信创国产化"
        },
        "问题四": {
          "用户状态": "不知道/知道",
          "匹配风格": "教育型、痛点型",
          "文案方向": "解决具体问题+案例证明+权威背书"
        }
      },
      "validation_points": [
        "用户画像多元（多角色）",
        "目标合理",
        "策略匹配",
        "考虑多投放渠道差异"
      ]
    }
  ]
}
