{
  "skill_name": "活动运营标准八步",
  "evals_type": "测试案例集",
  "version": "1.0",
  "测试案例": [
    {
      "案例编号": "eval_1",
      "案例名称": "电商平台大促活动策划",
      "难度": "medium",
      "背景": "某电商平台运营人员需要在双11期间策划一场拉新活动",
      "用户输入": {
        "活动目标": "拉新",
        "产品类型": "综合电商平台",
        "用户规模": "年活500万",
        "预算": "10万元",
        "时间周期": "2周"
      },
      "期望输出": {
        "必须包含": [
          "SMART化的活动目标",
          "目标用户画像",
          "活动玩法设计",
          "时间节奏规划",
          "资源物料清单",
          "数据指标体系",
          "风险应急预案",
          "执行SOP"
        ],
        "质量要求": [
          "目标可量化（如：新增用户≥5000）",
          "玩法有裂变机制",
          "时间规划分预热/正式/续热",
          "风险至少覆盖2种"
        ]
      },
      "评估要点": [
        "八步是否完整覆盖",
        "目标是否SMART化",
        "产出物是否可执行"
      ]
    },
    {
      "案例编号": "eval_2",
      "案例名称": "社群裂变活动策划",
      "难度": "simple",
      "背景": "某在线教育机构需要策划一场社群裂变活动来获取新用户",
      "用户输入": {
        "活动目标": "拉新+品牌曝光",
        "产品类型": "在线课程平台",
        "用户规模": "存量用户10万",
        "预算": "3万元",
        "时间周期": "1周"
      },
      "期望输出": {
        "必须包含": [
          "活动目标设定",
          "目标用户定位",
          "裂变玩法设计",
          "时间节奏",
          "物料清单",
          "数据追踪",
          "风险预案",
          "执行检查项"
        ],
        "质量要求": [
          "裂变机制设计合理",
          "时间紧凑适合快速启动",
          "低成本高传播设计"
        ]
      },
      "评估要点": [
        "裂变玩法是否可行",
        "成本控制是否合理",
        "执行难度是否适中"
      ]
    },
    {
      "案例编号": "eval_3",
      "案例名称": "会员日促活活动策划",
      "难度": "medium",
      "背景": "某社区团购平台需要策划月度会员日活动，提升老用户活跃度和复购",
      "用户输入": {
        "活动目标": "促活+复购",
        "产品类型": "社区团购",
        "用户规模": "月活50万",
        "预算": "5万元",
        "时间周期": "3天"
      },
      "期望输出": {
        "必须包含": [
          "促活目标量化",
          "老用户画像分析",
          "活动玩法设计",
          "时间节奏",
          "资源准备",
          "数据指标",
          "应急预案",
          "执行SOP"
        ],
        "质量要求": [
          "复购激励设计",
          "老用户专属感",
          "短期高爆发设计"
        ]
      },
      "评估要点": [
        "促活策略是否有效",
        "激励是否足够吸引老用户",
        "时间压缩下执行是否可行"
      ]
    }
