{
  "skill_name": "活动运营标准八步",
  "assess_type": "质量评估清单",
  "version": "1.0",
  "评估维度": [
    {
      "维度名称": "目标明确性",
      "权重": 20,
      "评估项": [
        {
          "项名称": "活动目标是否SMART化",
          "标准": "目标必须是具体的、可衡量的、可实现的、相关的、有时限的",
          "分值": 5
        },
        {
          "项名称": "目标是否与业务指标挂钩",
          "标准": "活动目标必须能够转化为业务指标（如GMV、DAU、付费率等）",
          "分值": 5
        },
        {
          "项名称": "是否设定基线和目标值",
          "标准": "必须有历史基线数据作为对比参照",
          "分值": 5
        }
      ]
    },
    {
      "维度名称": "流程完整性",
      "权重": 25,
      "评估项": [
        {
          "项名称": "八步是否全部覆盖",
          "标准": "必须包含：目标→用户→玩法→时间→资源→数据→风险→SOP",
          "分值": 5
        },
        {
          "项名称": "每步是否有明确产出",
          "标准": "每步必须产出可交付的文档/清单",
          "分值": 5
        },
        {
          "项名称": "步骤之间是否有逻辑关联",
          "标准": "步骤必须形成前后衔接的闭环",
          "分值": 5
        },
        {
          "项名称": "是否有检查项清单",
          "标准": "必须有上线前/中/后的检查项",
          "分值": 5
        }
      ]
    },
    {
      "维度名称": "可执行性",
      "权重": 20,
      "评估项": [
        {
          "项名称": "时间规划是否合理",
          "标准": "活动周期在7-14天内为佳，各阶段时间分配合理",
          "分值": 5
        },
        {
          "项名称": "资源需求是否明确",
          "标准": "必须列出物料、预算、人员等资源需求",
          "分值": 5
        },
        {
          "项名称": "人员分工是否清晰",
          "标准": "必须有明确的责任人和职责划分",
          "分值": 5
        }
      ]
    },
    {
      "维度名称": "风险控制",
      "权重": 15,
      "评估项": [
        {
          "项名称": "是否识别潜在风险",
          "标准": "必须识别技术、用户、竞品等至少3类风险",
          "分值": 5
        },
        {
          "项名称": "是否有应急预案",
          "标准": "必须有至少2个常见风险的应对方案",
          "分值": 5
        }
      ]
    },
    {
      "维度名称": "数据思维",
      "权重": 20,
      "评估项": [
        {
          "项名称": "核心KPI是否明确",
          "标准": "必须设定1-3个核心指标",
          "分值": 5
        },
        {
          "项名称": "过程指标是否完整",
          "标准": "必须有曝光→参与→转化的漏斗指标",
          "分值": 5
        },
        {
          "项名称": "数据埋点是否规划",
          "标准": "必须规划埋点方案和数据分析维度",
          "分值": 5
        }
      ]
    }
  ],
  "总分": 100,
  "及格线": 70,
  "评估说明": "每个评估项按5分制打分，总分100分，70分及格"
}
