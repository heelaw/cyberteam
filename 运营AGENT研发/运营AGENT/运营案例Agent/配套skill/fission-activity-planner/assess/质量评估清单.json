{
  "skill_name": "fission-activity-planner",
  "skill_version": "v1.0",
  "assessment_date": "2026-03-19",
  "assessor": "自动化评估",

  "quality_dimensions": [
    {
      "dimension": "目标明确性",
      "weight": 20,
      "description": "活动目标是否SMART化且合理",
      "criteria": [
        "目标具体可衡量",
        "目标可达成",
        "目标有时间限制",
        "优先级清晰"
      ],
      "pass_threshold": "3个以上SMART指标"
    },
    {
      "dimension": "机制有效性",
      "weight": 25,
      "description": "裂变机制是否有足够吸引力",
      "criteria": [
        "裂变类型选择合理",
        "激励方案有话题性",
        "激励原则完整（即时/损失/社交/稀缺）",
        "成本可控有防薅"
      ],
      "pass_threshold": "激励方案完整且有话题性"
    },
    {
      "dimension": "主题吸引力",
      "weight": 15,
      "description": "活动主题是否符合好主题的标准",
      "criteria": [
        "吸引力：一眼抓住注意力",
        "话题性：能引发传播",
        "相关性：与业务相关",
        "记忆点：容易记住"
      ],
      "pass_threshold": "满足3个以上标准"
    },
    {
      "dimension": "路径合理性",
      "weight": 20,
      "description": "用户路径是否顺畅高效",
      "criteria": [
        "新用户路径不超过5步",
        "老用户路径不超过5步",
        "入口要浅",
        "障碍要清"
      ],
      "pass_threshold": "两种路径都清晰"
    },
    {
      "dimension": "风险完备性",
      "weight": 20,
      "description": "风险评估和预案是否完整",
      "criteria": [
        "P0风险有识别",
        "P0风险有预案",
        "评估指标明确",
        "执行分工清晰"
      ],
      "pass_threshold": "P0风险100%有预案"
    }
  ],

  "critical_rules_compliance": {
    "must_follow": [
      "目标先行 - 先明确活动目标再设计",
      "激励要有话题性 - 奖励本身要能引发传播",
      "路径要短 - 从触达到参与不超过3步",
      "成本要可控 - 必须设定单人获客成本上限",
      "防薅要前置 - 方案设计阶段考虑防薅"
    ],
    "must_avoid": [
      "不设计单向获益",
      "不忽视新用户体验",
      "不跳过风险评估",
      "不承诺无法兑现的奖励",
      "不依赖单一渠道"
    ]
  },

  "overall_quality_threshold": 0.8,
  "version_history": [
    {"version": "v1.0", "date": "2026-03-19", "note": "初始版本"}
  ]
}
