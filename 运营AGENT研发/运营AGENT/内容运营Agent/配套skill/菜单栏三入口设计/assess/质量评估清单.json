{
  "skill_name": "菜单栏三入口设计",
  "version": "1.0",
  "quality_standards": {
    "critical_rules_compliance": {
      "权重": 30,
      "评估项": [
        {
          "条目": "禁止菜单命名模糊",
          "检查点": "不能用「更多」「其他」「关于」等模糊命名",
          "合格标准": "每个主菜单名称能准确表达功能"
        },
        {
          "条目": "禁止堆砌链接",
          "检查点": "核心功能1-3个即可，子菜单不超过5个",
          "合格标准": "功能精简，主次分明"
        },
        {
          "条目": "禁止没有转化入口",
          "检查点": "必须有至少一个转化引导菜单",
          "合格标准": "有明确的行动号召和转化路径"
        },
        {
          "条目": "禁止主菜单直接跳转",
          "检查点": "主菜单用子菜单承接跳转内容",
          "合格标准": "用户点击主菜单后有选择空间"
        },
        {
          "条目": "禁止过期内容",
          "检查点": "跳转页面必须长期有效",
          "合格标准": "提供链接有效性承诺"
        },
        {
          "条目": "禁止忽视移动端体验",
          "检查点": "跳转页面必须在手机端体验良好",
          "合格标准": "提供移动端适配说明"
        }
      ]
    },
    "workflow_compliance": {
      "权重": 40,
      "评估项": [
        {
          "步骤": "Step1-功能入口设计",
          "检查点": "三菜单命名+子菜单结构+功能优先级",
          "合格标准": "覆盖高频需求，布局合理"
        },
        {
          "步骤": "Step2-内容入口设计",
          "检查点": "内容分类体系+菜单配置+诱饵内容",
          "合格标准": "分类清晰，有热门内容推荐"
        },
        {
          "步骤": "Step3-转化入口设计",
          "检查点": "转化路径+菜单配置+联系方式",
          "合格标准": "转化路径清晰，有行动号召"
        }
      ]
    },
    "output_format": {
      "权重": 30,
      "评估项": [
        {
          "条目": "菜单命名方案",
          "检查点": "三个主菜单命名及子菜单结构",
          "合格标准": "可直接用于后台配置的完整方案"
        },
        {
          "条目": "内容分类配置",
          "检查点": "内容分类体系及跳转设置",
          "合格标准": "分类逻辑清晰，配置完整"
        },
        {
          "条目": "转化路径设计",
          "检查点": "转化入口及联系方式配置",
          "合格标准": "有低/中/高门槛转化设计"
        }
      ]
    }
  },
  "quality_score": {
    "总分": 100,
    "合格线": 75,
    "评分维度": ["Critical Rules合规(30%)", "Workflow执行(40%)", "输出格式(30%)"]
  }
}
