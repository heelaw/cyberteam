{
  "skill_name": "自动回复三要素",
  "version": "1.0",
  "quality_standards": {
    "critical_rules_compliance": {
      "权重": 30,
      "评估项": [
        {
          "条目": "禁止无价值回复",
          "检查点": "欢迎语必须有实质内容，不能只是感谢",
          "合格标准": "包含账号定位+价值承诺+行动指引"
        },
        {
          "条目": "禁止虚假承诺",
          "检查点": "不承诺做不到的事，如24小时必回复",
          "合格标准": "承诺与实际服务能力匹配"
        },
        {
          "条目": "禁止过度营销",
          "检查点": "首条回复不能是推销，要先给价值",
          "合格标准": "至少前3条回复是纯价值内容"
        },
        {
          "条目": "禁止无关键词",
          "检查点": "必须有至少10个关键词回复覆盖常见需求",
          "合格标准": "关键词列表完整，分类清晰"
        },
        {
          "条目": "禁止回复过长",
          "检查点": "单条回复不超过200字",
          "合格标准": "每条回复控制在100字内或分段"
        },
        {
          "条目": "禁止缺少人工入口",
          "检查点": "必须保留人工客服通道",
          "合格标准": "FAQ中有明确的人工联系入口"
        }
      ]
    },
    "workflow_compliance": {
      "权重": 40,
      "评估项": [
        {
          "步骤": "Step1-欢迎语设计",
          "检查点": "包含自我介绍+价值承诺+行动指引+互动诱饵",
          "合格标准": "100字内，四要素齐全"
        },
        {
          "步骤": "Step2-关键词回复配置",
          "检查点": "10-20个关键词，覆盖需求/问题/资源类",
          "合格标准": "关键词分类清晰，有对应回复"
        },
        {
          "步骤": "Step3-常见问题自动回复",
          "检查点": "FAQ覆盖TOP10问题，有人工入口",
          "合格标准": "问题分类合理，解决路径清晰"
        }
      ]
    },
    "output_format": {
      "权重": 30,
      "评估项": [
        {
          "条目": "欢迎语文案",
          "检查点": "可直接粘贴使用的文案",
          "合格标准": "有多个版本备选，含优化建议"
        },
        {
          "条目": "关键词配置表",
          "检查点": "可导入的关键词-回复对应表",
          "合格标准": "表格化，字段完整"
        },
        {
          "条目": "FAQ问题库",
          "检查点": "包含问题分类+回复内容+引导逻辑",
          "合格标准": "TOP10全覆盖，有更新机制"
        }
      ]
    }
  },
  "quality_score": {
    "总分": 100,
    "合格线": 75,
    "评分维度": ["Critical Rules合规(30%)", "Workflow执行(40%)", "输出格式(30%)"]
  }
}
