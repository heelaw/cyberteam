{
  "skill_name": "自动回复三要素",
  "version": "1.0",
  "eval_type": "skill_functional",
  "test_cases": [
    {
      "id": 1,
      "difficulty": "simple",
      "category": "基础回复设置",
      "description": "为简单定位的公众号设计自动回复",
      "input": {
        "account_style": "轻松活泼",
        "target_user_profile": "热爱美食的爱下厨人群",
        "common_questions": [
          "有什么菜谱推荐",
          "怎么联系你们",
          "有社群吗",
          "每日一道菜"
        ],
        "reply_objective": "引流至私域",
        "brand_keywords": ["美食", "下厨", "菜谱"]
      },
      "expected_output": {
        "must_include": [
          "语言风格：轻松活泼",
          "回复模板：50字以内",
          "行动引导：引导获取菜谱或加群",
          "三要素完整（风格+引导+精炼）"
        ],
        "output_structure": "风格+模板+引导",
        "min_score": 3
      },
      "evaluation_criteria": {
        "style": "风格是否匹配",
        "elements": "三要素是否完整",
        "clarity": "输出是否清晰"
      }
    },
    {
      "id": 2,
      "difficulty": "medium",
      "category": "多场景回复设计",
      "description": "为有多个常见问题的公众号设计关键词回复",
      "input": {
        "account_style": "专业亲切",
        "target_user_profile": "22-28岁职场新人，渴望快速成长",
        "common_questions": [
          "有学习资料吗",
          "怎么联系你们",
          "能帮我看简历吗",
          "有社群吗",
          "怎么提升沟通能力",
          "有线下活动吗",
          "怎么加入会员"
        ],
        "reply_objective": "引流至私域",
        "brand_keywords": ["成长", "进化", "职场"]
      },
      "expected_output": {
        "must_include": [
          "语言风格：专业亲切",
          "多个回复模板（至少5个关键词）",
          "每个模板50字以内",
          "行动引导明确",
          "三要素完整",
          "覆盖率报告"
        ],
        "output_structure": "风格+多个模板+引导+覆盖率",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "是否覆盖多场景",
        "elements": "三要素是否完整",
        "practicality": "建议是否具有实操性"
      }
    },
    {
      "id": 3,
      "difficulty": "hard",
      "category": "完整自动回复方案",
      "description": "设计包含被关注回复和关键词回复的完整方案",
      "input": {
        "account_style": "温暖有同理心",
        "target_user_profile": "18-35岁关注情感和自我成长的女性",
        "common_questions": [
          "感情遇到问题了",
          "怎么处理分手",
          "他不爱我了吗",
          "怎么提升自己",
          "有心理咨询吗",
          "怎么联系你们",
          "有什么课程",
          "怎么加入社群",
          "更新推送时间",
          "如何投稿"
        ],
        "reply_objective": "解答咨询",
        "brand_keywords": ["治愈", "陪伴", "成长"]
      },
      "expected_output": {
        "must_include": [
          "被关注回复设计",
          "关键词回复设计（至少8个关键词）",
          "语言风格：温暖有同理心",
          "每个回复30字以内",
          "每个回复包含明确行动引导",
          "三要素完整",
          "覆盖率≥80%",
          "优化建议"
        ],
        "output_structure": "完整自动回复方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "是否覆盖全部场景",
        "elements": "三要素是否完整",
        "design": "设计是否合理"
      }
    }
  ],
  "evaluation_methodology": {
    "scoring": "每个维度1-5分，5分制评分",
    "pass_criteria": "总分≥15分（满分25分），且每个维度≥3分",
    "process": "1.确定账号风格 2.收集常见问题 3.设计回复模板 4.确保三要素完整 5.控制字数 6.测试优化"
  }
}
