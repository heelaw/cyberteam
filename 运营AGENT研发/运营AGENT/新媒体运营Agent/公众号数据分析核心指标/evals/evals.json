{
  "skill_name": "公众号数据分析核心指标",
  "version": "1.0",
  "eval_type": "skill_functional",
  "test_cases": [
    {
      "id": 1,
      "difficulty": "simple",
      "category": "单篇文章效果分析",
      "description": "分析单篇推送的效果，计算核心指标",
      "input": {
        "analysis_period": "2024-03-15单篇文章",
        "account_type": "订阅号",
        "follower_count": 50000,
        "article_delivered": 45000,
        "article_reading": 3600,
        "article_original_click": 180,
        "article_shares": 36,
        "article_collects": 18
      },
      "expected_output": {
        "must_include": [
          "阅读率：8%（3600/45000）",
          "原文转化率：5%（180/3600）",
          "分享率：1%（36/3600）",
          "收藏率：0.5%（18/3600）",
          "诊断：阅读率正常，分享收藏偏低",
          "建议：增加实用性内容提升收藏分享"
        ],
        "output_structure": "指标计算+诊断+建议",
        "min_score": 3
      },
      "evaluation_criteria": {
        "accuracy": "指标计算是否正确",
        "diagnosis": "诊断是否准确",
        "clarity": "输出是否清晰"
      }
    },
    {
      "id": 2,
      "difficulty": "medium",
      "category": "月度运营数据分析",
      "description": "分析整月数据，评估用户增长和内容表现",
      "input": {
        "analysis_period": "2024年3月",
        "account_type": "订阅号",
        "follower_count": 35000,
        "new_followers": 2800,
        "cancelled_followers": 1600,
        "article_delivered": 28000,
        "article_reading": 4200,
        "article_shares": 118,
        "article_collects": 63
      },
      "expected_output": {
        "must_include": [
          "净增用户：1200人（3.55%）",
          "增长趋势：上升/稳定/下降",
          "阅读率：15%（4200/28000）",
          "分享率：2.81%（118/4200）",
          "收藏率：1.5%（63/4200）",
          "用户增长诊断",
          "内容表现诊断"
        ],
        "output_structure": "增长分析+内容分析+诊断",
        "min_score": 3
      },
      "evaluation_criteria": {
        "accuracy": "指标计算是否正确",
        "completeness": "是否覆盖全部指标",
        "diagnosis": "诊断是否准确"
      }
    },
    {
      "id": 3,
      "difficulty": "hard",
      "category": "多周期趋势综合分析",
      "description": "分析连续多个月的数据趋势，给出综合诊断和改进建议",
      "input": {
        "analysis_period": "2024年1-3月趋势分析",
        "account_type": "订阅号",
        "monthly_data": [
          {"month": "1月", "follower_count": 50000, "new_followers": 2000, "cancelled_followers": 500, "reading_rate": 8, "share_rate": 2},
          {"month": "2月", "follower_count": 52000, "new_followers": 2500, "cancelled_followers": 500, "reading_rate": 10, "share_rate": 3},
          {"month": "3月", "follower_count": 48000, "new_followers": 1500, "cancelled_followers": 5500, "reading_rate": 6, "share_rate": 1}
        ]
      },
      "expected_output": {
        "must_include": [
          "粉丝趋势：先增后降，3月大幅下降",
          "阅读率趋势：先升后降",
          "分享率趋势：先升后降",
          "3月异常分析：取关数异常升高原因",
          "综合诊断：内容质量波动或外部因素",
          "改进建议：稳定内容质量、排查取关原因"
        ],
        "output_structure": "趋势分析+综合诊断+建议",
        "min_score": 3
      },
      "evaluation_criteria": {
        "trend_analysis": "趋势分析是否正确",
        "depth": "分析是否有深度",
        "practicality": "建议是否具有实操性"
      }
    }
  ],
  "evaluation_methodology": {
    "scoring": "每个维度1-5分，5分制评分",
    "pass_criteria": "总分≥15分（满分25分），且每个维度≥3分",
    "process": "1.计算核心指标 2.分析指标健康度 3.诊断问题 4.给出改进建议"
  }
}
