{
  "skill_name": "痛点选题三步法",
  "version": "1.0",
  "eval_type": "skill_functional",
  "test_cases": [
    {
      "id": 1,
      "difficulty": "simple",
      "category": "基础痛点识别",
      "description": "从少量用户反馈中识别痛点并产出选题",
      "input": {
        "user_feedback_source": "私信",
        "raw_feedback_data": [
          "孩子写作业太磨蹭怎么办",
          "要不要给孩子报线上课",
          "怎么培养孩子阅读习惯",
          "孩子成绩不好着急"
        ],
        "feedback_count": 50,
        "account_positioning": "家庭教育指南",
        "target_user_profile": {
          "age_range": "30-40岁",
          "occupation": "小学生家长",
          "pain_points": ["孩子学习习惯", "教育方法"]
        },
        "topic_quantity": 5
      },
      "expected_output": {
        "must_include": [
          "关键词提取：作业磨蹭、报课、阅读习惯、成绩",
          "痛点识别：孩子学习习惯差、家长监督疲惫",
          "分类：执行型痛点、资源型痛点",
          "选题方向：孩子磨蹭的5个原因及对策",
          "优先级：高"
        ],
        "output_structure": "关键词+痛点+分类+选题+优先级",
        "min_score": 3
      },
      "evaluation_criteria": {
        "accuracy": "痛点识别是否准确",
        "classification": "分类是否正确",
        "clarity": "输出是否清晰"
      }
    },
    {
      "id": 2,
      "difficulty": "medium",
      "category": "深度痛点分析",
      "description": "从评论区提取大量痛点，进行深度分析并产出TOP选题",
      "input": {
        "user_feedback_source": "评论",
        "raw_feedback_data": [
          "加班没时间提升自己",
          "想转行但不知道从哪开始",
          "工作3年还是专员，晋升无望",
          "35岁职场焦虑怎么办",
          "工资太低想跳槽",
          "职场人际关系太复杂",
          "每天加班到10点身体扛不住",
          "不知道自己喜欢什么工作"
        ],
        "feedback_count": 120,
        "account_positioning": "95后职场新人成长指南",
        "target_user_profile": {
          "age_range": "22-28岁",
          "occupation": "职场新人1-3年",
          "pain_points": ["时间管理", "职业规划", "薪资增长"]
        },
        "topic_quantity": 10
      },
      "expected_output": {
        "must_include": [
          "关键词提取：加班、转行、晋升、焦虑、薪资、人际关系",
          "痛点归类：资源型（没时间）、决策型（转行）、动机型（焦虑）",
          "TOP5选题及理由",
          "优先级排序",
          "验证依据"
        ],
        "output_structure": "关键词+痛点+选题+优先级+验证",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "是否包含全部要素",
        "depth": "分析是否有深度",
        "practicality": "建议是否具有实操性"
      }
    },
    {
      "id": 3,
      "difficulty": "hard",
      "category": "多渠道综合分析",
      "description": "从多个渠道（评论、私信、搜索指数）综合分析痛点，区分真痛点和伪痛点",
      "input": {
        "user_feedback_source": "混合",
        "raw_feedback_data": {
          "comments": ["怎么做菜更好吃", "新手入门选什么锅", "家常菜做法大全"],
          "private_messages": ["想学做菜但无从下手", "有什么简单易学的菜谱", "厨房小白求带"],
          "search_keywords": ["新手学做菜", "零基础烹饪", "简单家常菜"]
        },
        "feedback_count": 200,
        "account_positioning": "美食烹饪教程",
        "target_user_profile": {
          "age_range": "25-45岁",
          "occupation": "厨房新手",
          "pain_points": ["不知道做什么", "做法太复杂", "工具不会用"]
        },
        "topic_quantity": 10
      },
      "expected_output": {
        "must_include": [
          "多渠道数据汇总分析",
          "真痛点vs伪痛点区分",
          "痛点分类：认知型/执行型/资源型",
          "TOP5选题及验证依据",
          "优先级排序及理由"
        ],
        "output_structure": "数据汇总+痛点区分+分类+选题+优先级",
        "min_score": 3
      },
      "evaluation_criteria": {
        "verification": "数据验证是否充分",
        "differentiation": "真伪痛点区分是否准确",
        "depth": "分析是否有深度"
      }
    }
  ],
  "evaluation_methodology": {
    "scoring": "每个维度1-5分，5分制评分",
    "pass_criteria": "总分≥15分（满分25分），且每个维度≥3分",
    "process": "1.收集用户反馈数据 2.提取关键词和痛点 3.进行分类和追问 4.验证痛点真实性 5.产出TOP选题"
  }
}
