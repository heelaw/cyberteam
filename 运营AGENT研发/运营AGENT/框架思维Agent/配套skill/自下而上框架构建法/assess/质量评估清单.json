          "levels": {
            "excellent": "类别之间边界完全清晰，无交叉",
            "good": "类别边界基本清晰",
            "acceptable": "存在轻微边界模糊",
            "poor": "类别之间存在严重交叉"
          }
        },
        {
          "id": "S2",
          "description": "类别数量适中（3-7个）",
          "levels": {
            "excellent": "类别数量在3-7个之间，且每个类别都有实质内容",
            "good": "类别数量在合理范围内",
            "acceptable": "类别数量略超范围但可接受",
            "poor": "类别过多或过少"
          }
        },
        {
          "id": "S3",
          "description": "类别关系明确",
          "levels": {
            "excellent": "各类别之间的关联关系被清晰标注",
            "good": "类别关系基本明确",
            "acceptable": "类别关系有描述但不够清晰",
            "poor": "类别之间关系混乱"
          }
        }
      ]
    },
    {
