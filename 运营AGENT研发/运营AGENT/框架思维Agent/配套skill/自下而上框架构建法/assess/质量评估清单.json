            "acceptable": "有调整但不够深入",
            "poor": "发现问题不愿修改"
          }
        },
        {
          "id": "R3",
          "description": "用户确认框架可用",
          "levels": {
            "excellent": "用户完全理解并认同框架结构",
            "good": "用户基本认可框架",
            "acceptable": "用户有部分疑问但基本接受",
            "poor": "用户不认可或无法理解框架"
          }
        }
      ]
    },
    {
      "dimension": "独特个性",
      "weight": 0.10,
      "description": "是否有独特价值",
      "criteria": [
        {
          "id": "U1",
          "description": "保持开放性",
          "levels": {
            "excellent": "完全没有预设干扰，开放收集信息",
            "good": "基本保持开放性",
            "acceptable": "存在轻微预设倾向",
            "poor": "带着结论去找证据"
          }
        },
        {
          "id": "U2",
          "description": "能发现独特洞见",
          "levels": {
            "excellent": "通过归类发现新的规律或洞见",
            "good": "能发现一些新规律",
            "acceptable": "发现有限",
            "poor": "只是简单分类，无新发现"
          }
        }
      ]
    },
    {
