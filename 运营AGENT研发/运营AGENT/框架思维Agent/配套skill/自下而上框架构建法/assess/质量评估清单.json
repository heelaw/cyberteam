        {
          "id": "P1",
          "description": "框架能解释已知信息",
          "levels": {
            "excellent": "框架能归类95%以上的收集信息",
            "good": "框架能归类大部分信息",
            "acceptable": "框架能归类基本重要信息",
            "poor": "框架与收集信息脱节"
          }
        },
        {
          "id": "P2",
          "description": "核心要素被识别",
          "levels": {
            "excellent": "高频出现的概念和关键词被准确识别",
            "good": "识别出大部分核心要素",
            "acceptable": "核心要素识别基本完整",
            "poor": "核心要素识别有重大遗漏"
          }
        },
        {
          "id": "P3",
          "description": "框架可指导后续学习",
          "levels": {
            "excellent": "框架可直接指导后续深入学习和实践",
            "good": "框架对学习有一定指导意义",
            "acceptable": "框架指导意义有限",
            "poor": "框架过于理论化，无实用价值"
          }
        }
      ]
    },
    {
      "dimension": "专业性",
      "weight": 0.20,
      "description": "归类和框架是否体现专业深度",
      "criteria": [
        {
          "id": "S1",
