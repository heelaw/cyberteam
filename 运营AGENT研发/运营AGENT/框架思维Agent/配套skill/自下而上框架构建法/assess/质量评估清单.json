  "scoring_guide": {
    "excellent": 5,
    "good": 4,
    "acceptable": 3,
    "poor": 1
  },
  "pass_threshold": 85,
  "max_score": 100,
  "calculation_method": "各维度得分乘以权重后累加，满分100分"
