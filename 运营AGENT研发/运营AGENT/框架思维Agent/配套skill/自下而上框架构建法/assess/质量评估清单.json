          "description": "使用标准输出模板",
          "levels": {
            "excellent": "完全按照模板格式输出",
            "good": "基本按照模板格式",
            "acceptable": "格式基本规范",
            "poor": "格式混乱"
          }
        },
        {
          "id": "N2",
          "description": "信息归类记录清晰",
          "levels": {
            "excellent": "归类过程记录完整可追溯",
            "good": "归类记录基本完整",
            "acceptable": "归类记录有缺失",
            "poor": "没有归类记录"
          }
        }
      ]
    }
