  "assessment_dimensions": [
    {
      "dimension": "完整性",
      "weight": 0.20,
      "description": "信息收集和框架构建是否完整",
      "criteria": [
        {
          "id": "C1",
          "description": "信息来源覆盖主要渠道",
          "levels": {
            "excellent": "覆盖3个以上主要信息来源（书籍/课程/文章/案例/专家等）",
            "good": "覆盖2-3个主要信息来源",
            "acceptable": "信息来源较少但覆盖核心渠道",
            "poor": "信息来源单一或不相关"
          }
        },
        {
          "id": "C2",
          "description": "收集数量达到饱和",
          "levels": {
            "excellent": "继续收集边际收益明显递减",
            "good": "收集数量基本足够",
            "acceptable": "收集数量略少但可接受",
            "poor": "收集不足就急于归类"
          }
        },
        {
          "id": "C3",
          "description": "每个来源有核心观点记录",
          "levels": {
            "excellent": "每个来源都有实质性核心观点",
            "good": "大部分来源有核心观点",
            "acceptable": "部分来源只有标题无实质内容",
            "poor": "存在空来源或只有标题"
          }
        }
      ]
    },
    {
