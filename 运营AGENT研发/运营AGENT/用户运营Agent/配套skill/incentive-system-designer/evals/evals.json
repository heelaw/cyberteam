{
  "skill_name": "incentive-system-designer",
  "测试案例": [
    {
      "id": "eval-1",
      "难度": "medium",
      "案例": "某在线阅读APP需要设计激励体系，提升用户日均阅读时长和付费转化",
      "输入": {
        "target_behaviors": ["每日阅读30分钟以上", "主动评论互动", "分享内容给好友", "购买会员"],
        "user_segments": [
          {"name": "免费用户", "占比": "70%"},
          {"name": "付费会员", "占比": "30%"}
        ]
      },
      "预期输出": {
        "incentive_system": {
          "core_loop": "阅读行为→获得积分→兑换权益→更多阅读",
          "elements": {
            "points": {
              "name": "阅币",
              "rules": "阅读30分钟+10阅币，评论+5阅币，分享+10阅币",
              "usage": "可兑换会员折扣券、实体书、周边"
            },
            "levels": {
              "name": "阅读等级（L1-L10）",
              "requirements": ["Lv1: 0阅读时长", "Lv3: 100小时", "Lv5: 500小时", "Lv8: 2000小时", "Lv10: 5000小时"],
              "benefits": ["Lv3: 评论权限", "Lv5: 专属徽章", "Lv8: 免费阅读券", "Lv10: 专属客服"]
            },
            "badges": {
              "name": "成就勋章",
              "criteria": ["连续阅读7天: 坚持勋章", "分享10次: 传播达人", "购买会员: 尊贵会员", "阅读100本书: 阅读王者"]
            }
          }
        },
        "behavior_guidance": [
          {"target_behavior": "每日阅读30分钟+", "incentive": "+10阅币+算入阅读时长", "expected_result": "日均阅读时长从15分钟提升至30分钟"},
          {"target_behavior": "主动评论", "incentive": "+5阅币+可能被推荐", "expected_result": "评论率从5%提升至15%"},
          {"target_behavior": "分享内容", "incentive": "+10阅币+好友同得阅币", "expected_result": "分享率提升50%"},
          {"target_behavior": "购买会员", "incentive": "专属勋章+VIP内容+续费折扣", "expected_result": "付费转化从5%提升至10%"}
        ]
      }
    }
  ],
  "评分标准": {
    "激励有效性": "激励是否能有效驱动目标行为",
    "系统完整性": "积分/等级/勋章是否齐全且可循环",
    "可持续性": "激励成本是否可控，长期可行",
    "技术可行": "是否可实现且可追踪效果"
  }
}
