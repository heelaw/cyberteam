        "会员体系": {
          "等级设计": "铜牌（0-500成长值）、银牌（500-2000）、金牌（2000+）",
          "成长值获取": "消费1元=1成长值，评论=5成长值，分享=10成长值",
          "权益设计": {
            "铜牌": "新人专享券、积分翻倍",
