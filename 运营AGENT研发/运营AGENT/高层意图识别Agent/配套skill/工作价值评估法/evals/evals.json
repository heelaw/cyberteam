{
  "skill_name": "工作价值评估法",
  "version": "1.0",
  "eval_type": "skill_functional",
  "test_cases": [
    {
      "id": 1,
      "difficulty": "simple",
      "category": "基础评估",
      "input": {
        "work_item": "这个项目值不值得做？",
        "context": {
          "strategic_alignment": "中",
          "urgency": 3,
          "resource_constraint": "中等"
        }
      },
      "expected_output": {
        "must_include": ["价值定义：核心价值(业务价值/用户价值/战略价值)", "成本评估：时间成本/人力成本/资源成本", "优先级判断：P0/P1/P2/P3", "建议：做/不做/延后/简化"],
        "output_structure": "价值+成本+优先级+建议",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "是否包含全部要素",
        "accuracy": "评估是否准确",
        "clarity": "输出是否清晰可读",
        "practicality": "建议是否具有实操性"
      }
    },
    {
      "id": 2,
      "difficulty": "medium",
      "category": "工作评估",
      "input": {
        "work_item": "团队要我花时间做汇报材料，我觉得没价值，请帮我评估",
        "context": {
          "strategic_alignment": "低",
          "urgency": 2,
          "resource_constraint": "紧张"
        }
      },
      "expected_output": {
        "must_include": ["价值定义：信息同步/决策支持/管理需要", "成本评估：时间成本(预估xx小时)", "机会成本：可用于更高价值工作", "优先级判断：P1-需要做但可简化", "建议：做但简化/提供模板/减少频率"],
        "output_structure": "价值+成本+机会成本+优先级+建议",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "是否包含全部要素",
        "opportunity_cost_awareness": "是否考虑机会成本",
        "practicality": "建议是否具有实操性",
        "clarity": "输出是否清晰可读"
      }
    },
    {
      "id": 3,
      "difficulty": "hard",
      "category": "复杂评估",
      "input": {
        "work_item": "公司要开发一个内部管理系统，请评估是否值得做",
        "context": {
          "strategic_alignment": "高",
          "urgency": 3,
          "resource_constraint": "中等"
        }
      },
      "expected_output": {
        "must_include": ["价值定义：业务价值(效率提升/数据沉淀)+战略价值(数字化)", "成本评估：开发成本(xxx万)+运维成本+学习成本", "机会成本：如果不做可以用这些资源做什么", "优先级判断：P1-有价值但非紧急", "建议：自建/采购/外包+实施路径"],
        "output_structure": "价值+成本+机会成本+优先级+建议+实施路径",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "是否包含全部要素",
        "depth": "分析是否有深度",
        "practicality": "建议是否具有实操性",
        "opportunity_cost_awareness": "机会成本分析是否充分"
      }
    }
  ],
  "evaluation_methodology": {
    "scoring": "每个维度1-5分，5分制评分",
    "pass_criteria": "总分≥15分（满分25分），且每个维度≥3分",
    "process": "1.明确工作的价值 2.评估所需成本 3.判断优先级 4.给出具体建议"
  }
}
