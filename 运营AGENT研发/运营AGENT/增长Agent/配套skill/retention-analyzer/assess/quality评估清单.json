{
  "skill_name": "retention-analyzer",
  "version": "1.0.0",
  "assess_type": "quality",
  "metrics": [
    {
      "id": "m1",
      "name": "留存数据完整性",
      "description": "是否包含次日/7日/30日留存数据",
      "type": "count",
      "threshold": 3,
      "weight": 15
    },
    {
      "id": "m2",
      "name": "留存曲线分析",
      "description": "是否判断留存曲线类型",
      "type": "binary",
      "threshold": true,
      "weight": 15
    },
    {
      "id": "m3",
      "name": "流失原因数量",
      "description": "是否识别3个以上主要流失原因",
      "type": "count",
      "threshold": 3,
      "weight": 20
    },
    {
      "id": "m4",
      "name": "用户分层分析",
      "description": "是否按用户群分层分析留存",
      "type": "count",
      "threshold": 2,
      "weight": 15
    },
    {
      "id": "m5",
      "name": "留存策略数量",
      "description": "是否为每个流失原因提供优化策略",
      "type": "count",
      "threshold": 3,
      "weight": 15
    },
    {
      "id": "m6",
      "name": "预警机制",
      "description": "是否设计流失预警机制",
      "type": "binary",
      "threshold": true,
      "weight": 10
    },
    {
      "id": "m7",
      "name": "召回策略",
      "description": "是否提供用户召回策略",
      "type": "binary",
      "threshold": true,
      "weight": 10
    }
  ],
  "pass_threshold": 0.85,
  "version_history": [
    {
      "version": "1.0.0",
      "created": "2026-03-17",
      "notes": "初始版本"
    }
  ]
}
