{
  "skill_name": "热点话题四渠道发现法",
  "version": "1.0",
  "eval_type": "skill_functional",
  "test_cases": [
    {
      "id": 1,
      "difficulty": "simple",
      "category": "基础话题",
      "input": {
        "scenario": "产品经理社区，每周策划5个工作日话题"
      },
      "expected_output": {
        "must_include": ["四渠道监测", "话题筛选评分", "执行方案", "排期表"],
        "output_structure": "监测+筛选+执行+排期",
        "min_score": 3
      },
      "evaluation_criteria": {
        "completeness": "是否完整",
        "feasibility": "是否可行"
      }
    },
    {
      "id": 2,
      "difficulty": "medium",
      "category": "热点借势",
      "input": {
        "scenario": "AI工具热点，策划产品经理如何用AI工具的话题"
      },
      "expected_output": {
        "must_include": ["热点相关性分析", "话题角度设计", "执行方案", "效果指标"],
        "output_structure": "分析+角度+执行+指标",
        "min_score": 3
      },
      "evaluation_criteria": {
        "creativity": "角度是否有新意",
        "feasibility": "是否可执行"
      }
    },
    {
      "id": 3,
      "difficulty": "hard",
      "category": "体系化建设",
      "input": {
        "scenario": "建立可持续话题体系，支撑1000+活跃用户"
      },
      "expected_output": {
        "must_include": ["话题分类体系", "常青话题库", "监测机制", "SOP", "团队分工"],
        "output_structure": "完整体系方案",
        "min_score": 3
      },
      "evaluation_criteria": {
        "systematic": "体系是否完整",
        "scalable": "是否可规模化"
      }
    }
  ],
  "evaluation_methodology": {
    "scoring": "每个维度1-5分，5分制评分",
    "pass_criteria": "总分≥15分（满分25分），且每个维度≥3分",
    "process": "1.四渠道监测 2.话题筛选 3.执行策划 4.效果追踪 5.复盘优化"
  }
}
