{
  "version": "1.0",
  "test_cases": [
    {
      "id": "1",
      "scenario": "电商业务模型诊断",
      "description": "诊断一个电商平台的业务模型，识别转化环节问题",
      "difficulty": "medium",
      "input": {
        "model": {
          "stages": ["曝光", "点击", "注册", "首单", "复购"]
        },
        "metrics": {
          "曝光": 100000,
          "点击": 10000,
          "注册": 2000,
          "首单": 400,
          "复购": 80
        }
      },
      "expected_output": {
        "issues": ["首单转化率20%低于行业平均25%", "复购率20%较低"],
        "recommendations": ["优化首单优惠策略", "建立会员体系提升复购"]
      },
      "evaluation_points": [
        "准确识别首单转化率偏低",
        "准确识别复购率问题"
      ]
    },
    {
      "id": "2",
      "scenario": "SaaS产品模型诊断",
      "description": "诊断一个SaaS产品的业务模型",
      "difficulty": "simple",
      "input": {
        "model": {
          "stages": ["访问", "注册", "激活", "付费", "续费"]
        },
        "metrics": {
          "访问": 50000,
          "注册": 5000,
          "激活": 2500,
          "付费": 500,
          "续费": 400
        }
      },
      "expected_output": {
        "issues": ["激活率50%需提升"]
      },
      "evaluation_points": [
        "识别激活环节问题"
      ]
    }
  ],
  "evaluation_criteria": {
    "diagnosis_accuracy": "问题识别准确",
    "recommendation_quality": "建议具体可执行",
    "follow_up_plan": "改进计划清晰"
  }
}
